apps/routerconsole/jsp/favicon.ico

# Gradle
.gradle/
!gradle/wrapper/
!gradle/wrapper/*.jar
!gradle/wrapper/*.properties

# Gradle build output directories (comprehensive)
**/build/
!build/README.md
!pkg-temp/README.md
!dist/README.md

# Gradle-specific files
.gradle/
**/.gradle/
**/gradlew
**/gradlew.bat
**/gradle-wrapper.jar

# Gradle cache and daemon directories (if accidentally created in project)
**/.gradle/caches/
**/.gradle/daemon/
**/.gradle/native/
**/.gradle/notifications/
**/.gradle/workers/
**/.gradle/.tmp/
**/.gradle/build-scan-data/

# Gradle test output
**/build/test-results/
**/build/reports/
**/build/tmp/
**/build/classes/
**/build/resources/

# Gradle wrapper output
gradle/wrapper/.gradle/

# Gradle build artifacts in bin directories
**/bin/
!**/bin/README.md


<?xml version="1.0"?>
<ruleset name="I2P+ PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Focused PMD ruleset for I2P+ project.
        Excludes noisy style rules and false-positive-prone rules for networking code.
    </description>

    <exclude-pattern>.*/build/.*</exclude-pattern>
    <exclude-pattern>.*/target/.*</exclude-pattern>
    <exclude-pattern>.*/dist/.*</exclude-pattern>
    <exclude-pattern>.*/.*\.jar</exclude-pattern>
    <exclude-pattern>.*/.*\.class</exclude-pattern>
    <exclude-pattern>.*/.*\.war</exclude-pattern>

    <!-- Security -->
    <rule ref="category/java/security.xml"/>

    <!-- Error-prone, minus noisy rules -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="EmptyCatchBlock"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AssignmentInOperand"/>
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="NullAssignment"/>
        <exclude name="OneDeclarationPerLine"/>
        <exclude name="UnusedFormalParameter"/>
        <exclude name="UnusedAssignment"/>
        <exclude name="UnusedPrivateField"/>
        <exclude name="UnusedPrivateMethod"/>
        <exclude name="ForLoopVariableCount"/>
        <exclude name="AvoidReassigningLoopVariables"/>
        <exclude name="DoNotTerminateVM"/>
        <exclude name="DoNotCallGarbageCollectionExplicitly"/>
        <exclude name="MissingSerialVersionUID"/>
    </rule>

    <!-- Multithreading: only genuine bug risks, not style -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="AvoidSynchronizedStatement"/>
        <exclude name="AvoidSynchronizedAtMethodLevel"/>
        <exclude name="AvoidUsingVolatile"/>
        <exclude name="DoNotUseThreads"/>
        <exclude name="UseConcurrentHashMap"/>
    </rule>

</ruleset>

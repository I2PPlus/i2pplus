<?xml version="1.0"?>
<ruleset name="I2P+ PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Focused PMD ruleset for I2P+ project.
        Excludes noisy style rules and false-positive-prone rules for networking code.
    </description>

    <exclude-pattern>.*/build/.*</exclude-pattern>
    <exclude-pattern>.*/target/.*</exclude-pattern>
    <exclude-pattern>.*/dist/.*</exclude-pattern>
    <exclude-pattern>.*/.*\.jar</exclude-pattern>
    <exclude-pattern>.*/.*\.class</exclude-pattern>
    <exclude-pattern>.*/.*\.war</exclude-pattern>
    <exclude-pattern>.*/test/.*</exclude-pattern>
    <exclude-pattern>.*/demo/.*</exclude-pattern>
    <exclude-pattern>.*/tmp/.*</exclude-pattern>
    <exclude-pattern>.*/jetty/.*</exclude-pattern>
    <exclude-pattern>.*/wrapper/.*</exclude-pattern>
    <exclude-pattern>.*/pack200/.*</exclude-pattern>
    <exclude-pattern>.*/org/apache/.*</exclude-pattern>
    <exclude-pattern>.*/org/bouncycastle/.*</exclude-pattern>
    <exclude-pattern>.*/org/cybergarage/.*</exclude-pattern>
    <exclude-pattern>.*/com/maxmind/.*</exclude-pattern>
    <exclude-pattern>.*/com/southernstorm/.*</exclude-pattern>
    <exclude-pattern>.*/org/json/simple/.*</exclude-pattern>
    <exclude-pattern>.*/gnu/.*</exclude-pattern>
    <exclude-pattern>.*/com/google/.*</exclude-pattern>
    <exclude-pattern>.*_jsp\.java</exclude-pattern>

    <!-- Third-party exclusions -->
    <exclude-pattern>.*/net/i2p/apache/.*</exclude-pattern>
    <exclude-pattern>.*/org/apache/.*</exclude-pattern>
    <exclude-pattern>.*/org/bouncycastle/.*</exclude-pattern>
    <exclude-pattern>.*/org/cybergarage/.*</exclude-pattern>
    <exclude-pattern>.*/org/minidns/.*</exclude-pattern>
    <exclude-pattern>.*/org/json/.*</exclude-pattern>
    <exclude-pattern>.*/org/xlattice/.*</exclude-pattern>
    <exclude-pattern>.*/org/rrd4j/.*</exclude-pattern>
    <exclude-pattern>.*/org/jfree/.*</exclude-pattern>
    <exclude-pattern>.*/com/southernstorm/.*</exclude-pattern>
    <exclude-pattern>.*/com/maxmind/.*</exclude-pattern>
    <exclude-pattern>.*/com/mpatric/.*</exclude-pattern>
    <exclude-pattern>.*/com/tomgibara/.*</exclude-pattern>
    <exclude-pattern>.*/gnu/.*</exclude-pattern>
    <exclude-pattern>.*/io/pack200/.*</exclude-pattern>
    <exclude-pattern>.*/edu/internet2/.*</exclude-pattern>
    <exclude-pattern>.*/com/vuze/.*</exclude-pattern>
    <exclude-pattern>.*/net/metanotion/.*</exclude-pattern>
    <exclude-pattern>.*/com/thetransactioncompany/.*</exclude-pattern>
    <exclude-pattern>.*/com/google/zxing/.*</exclude-pattern>
    <exclude-pattern>.*/com/docuverse/.*</exclude-pattern>
    <exclude-pattern>.*/org/freenetproject/.*</exclude-pattern>
    <!-- net/i2p/util/Translate.java: StringBuffer required by MessageFormat.format(Object[], StringBuffer, FieldPosition) API -->
    <exclude-pattern>.*/net/i2p/util/Translate\.java</exclude-pattern>
    <!-- IRC pong buffers are shared across threads and mutated; StringBuffer sync is required -->
    <exclude-pattern>.*/net/i2p/i2ptunnel/I2PTunnelIRCClient\.java</exclude-pattern>
    <exclude-pattern>.*/net/i2p/i2ptunnel/socks/I2PSOCKSIRCTunnel\.java</exclude-pattern>

    <!-- Security -->
    <rule ref="category/java/security.xml"/>

    <!-- Error-prone, minus noisy rules -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="EmptyCatchBlock"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AssignmentInOperand"/>
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="NullAssignment"/>
        <exclude name="OneDeclarationPerLine"/>
        <exclude name="UnusedFormalParameter"/>
        <exclude name="UnusedAssignment"/>
        <exclude name="UnusedPrivateField"/>
        <exclude name="UnusedPrivateMethod"/>
        <exclude name="ForLoopVariableCount"/>
        <exclude name="AvoidReassigningLoopVariables"/>
        <exclude name="DoNotTerminateVM"/>
        <exclude name="DoNotCallGarbageCollectionExplicitly"/>
        <exclude name="MissingSerialVersionUID"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <!-- High noise/style rules -->
        <exclude name="ReturnEmptyCollectionRatherThanNull"/>
        <exclude name="ReplaceJavaUtilDate"/>
        <exclude name="AvoidImplicitlyRecompilingRegex"/>
        <exclude name="ConstructorCallsOverridableMethod"/>
        <exclude name="UseLocaleWithCaseConversions"/>
        <exclude name="AvoidUnnecessaryStringBuilderCreation"/>
        <exclude name="AvoidConcatInAppend"/>
        <exclude name="ImproperVariableName"/>
        <!-- CompareObjectsWithEquals: ~95% FP on enum/constant comparison patterns -->
        <exclude name="CompareObjectsWithEquals"/>
        <!-- CloseResource: ~95% false positives in this networking codebase
             (socket streams, I2P streaming connections, NIO channels,
              thread pool property reads, lifecycle-managed accept() handlers).
             Keep the 10 genuine TWR fixes; suppress the noise. -->
        <exclude name="CloseResource"/>
    </rule>

    <!-- Multithreading: only genuine bug risks, not style -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="AvoidSynchronizedStatement"/>
        <exclude name="AvoidSynchronizedAtMethodLevel"/>
        <exclude name="AvoidUsingVolatile"/>
        <exclude name="DoNotUseThreads"/>
        <exclude name="UseConcurrentHashMap"/>
        <exclude name="DontCallThreadRun"/>
    </rule>

    <!-- jPinpoint: performance, threading, memory, sustainability -->
    <rule ref="tools/pmd/ruleset-java-jpinpoint.xml">
        <exclude name="AvoidTimeUnitConfusion"/>
        <exclude name="UsingSuppressWarnings"/>
        <exclude name="AvoidUnguardedAssignmentToNonFinalFieldsInObjectsUsingSynchronized"/>
        <exclude name="AvoidUnguardedMutableFieldsInObjectsUsingSynchronized"/>
        <exclude name="AvoidMutableStaticFields"/>
        <exclude name="AvoidConstantsInInterface"/>
        <exclude name="SynchronizingForLocalVars"/>
        <exclude name="UnresolvedType"/>
        <exclude name="AvoidIncrementOrDecrementForVolatileField"/>
        <exclude name="AvoidMutableLists"/>
        <exclude name="AvoidHardcodedConnectionConfig"/>
        <exclude name="AvoidDecimalAndChoiceFormatAsField"/>
        <exclude name="LetFieldsMeetSerializable"/>
        <exclude name="NonComparableMapKeys"/>
        <exclude name="NonComparableSetElements"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="MissingFieldInHashCode"/>
        <exclude name="LimitWildcardStaticImports"/>
        <exclude name="AvoidMultipleConcatStatements"/>
        <exclude name="AvoidLoadingAllFromFile"/>
        <exclude name="MissingFieldInEquals"/>
        <!-- Equals/hashCode rules: excluded by user request (high noise, low signal) -->
        <exclude name="ImplementEqualsHashCodeOnValueObjects"/>
        <exclude name="FieldOfHashCodeMissingInEquals"/>
    </rule>

</ruleset>

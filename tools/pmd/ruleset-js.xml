<?xml version="1.0"?>
<ruleset name="I2P+ PMD JavaScript Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Focused PMD ruleset for I2P+ JavaScript code.
    </description>

    <exclude-pattern>.*/build/.*</exclude-pattern>
    <exclude-pattern>.*/target/.*</exclude-pattern>
    <exclude-pattern>.*/dist/.*</exclude-pattern>
    <exclude-pattern>.*/.*\.min\.js$</exclude-pattern>
    <exclude-pattern>.*/vendor/.*</exclude-pattern>
    <exclude-pattern>.*/jdenticon\.js$</exclude-pattern>
    <exclude-pattern>.*/morphdom\.js$</exclude-pattern>

    <rule ref="category/ecmascript/codestyle.xml">
        <exclude name="AssignmentInOperand"/>
    </rule>
    <rule ref="category/ecmascript/bestpractices.xml">
        <exclude name="GlobalVariable"/>
    </rule>
    <rule ref="category/ecmascript/errorprone.xml"/>

</ruleset>

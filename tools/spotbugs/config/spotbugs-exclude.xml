<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude all third-party libraries and only analyze I2P core code -->
    
    <!-- Exclude Apache Commons libraries -->
    <Match>
        <Class name="~org\.apache\.commons.*" />
    </Match>
    
    <!-- Exclude Jetty libraries -->
    <Match>
        <Class name="~org\.mortbay\.jetty.*" />
    </Match>
    <Match>
        <Class name="~org\.eclipse\.jetty.*" />
    </Match>
    
    <!-- Exclude Jasper/Servlet libraries -->
    <Match>
        <Class name="~org\.apache\.jasper.*" />
    </Match>
    <Match>
        <Class name="~javax\.servlet.*" />
    </Match>
    
    <!-- Exclude JRobin -->
    <Match>
        <Class name="~org\.jrobin.*" />
    </Match>
    
    <!-- Exclude JSON-RPC -->
    <Match>
        <Class name="~org\.json.*" />
    </Match>
    
    <!-- Exclude DNS libraries -->
    <Match>
        <Class name="~org\.minidns.*" />
    </Match>
    
    <!-- Exclude Noise protocol -->
    <Match>
        <Class name="~com\.southernstorm\.noise.*" />
    </Match>
    
    <!-- Exclude MaxMind GeoIP -->
    <Match>
        <Class name="~com\.maxmind.*" />
    </Match>
    
    <!-- Exclude MP3agic -->
    <Match>
        <Class name="~com\.mpatric\.mp3agic.*" />
    </Match>
    
    <!-- Exclude Bouncy Castle -->
    <Match>
        <Class name="~org\.bouncycastle.*" />
    </Match>
    
    <!-- Exclude Guava -->
    <Match>
        <Class name="~com\.google\.common.*" />
    </Match>
    
    <!-- Exclude SLF4J -->
    <Match>
        <Class name="~org\.slf4j.*" />
    </Match>
    
    <!-- Exclude Pack200 -->
    <Match>
        <Class name="~com\.sun\.java\.util\.jar\.pack.*" />
    </Match>
    
    <!-- Exclude system tray libraries -->
    <Match>
        <Class name="~java\.awt\..*" />
    </Match>
    
    <!-- Exclude any class from standard library packages -->
    <Match>
        <Class name="~java\..*" />
    </Match>
    <Match>
        <Class name="~javax\..*" />
    </Match>
    
    <!-- Exclude all other third-party packages -->
    <Match>
        <Class name="~com\.(?!i2p).*" />
    </Match>
    <Match>
        <Class name="~org\.(?!i2p).*" />
    </Match>
    <Match>
        <Class name="~net\.(?!i2p).*" />
    </Match>
    <Match>
        <Class name="~edu\..*" />
    </Match>
    
    <!-- Exclude GNU libraries (bundled third-party) -->
    <Match>
        <Class name="~gnu\..*" />
    </Match>

    <!-- Exclude compiled resource bundles (from PO translations) -->
    <Match>
        <Class name="~.*\.messages_[a-z]{2}.*" />
    </Match>
    
    <!-- Exclude Pack200 -->
    <Match>
        <Class name="~io\.pack200.*" />
    </Match>

    <!-- Exclude DM_DEFAULT_ENCODING - I2P uses UTF-8 throughout, hits are false positives -->
    <Match>
        <Bug pattern="DM_DEFAULT" />
    </Match>

    <!-- Exclude EI_EXPOSE_REP - exposing internal representation, standard JavaBean pattern -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 - same as above -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

    <!-- Exclude SF_SWITCH_NO_DEFAULT - intentional explicit case handling -->
    <Match>
        <Bug pattern="SF_SWITCH_NO_DEFAULT" />
    </Match>

    <!-- False Positives from Static Analysis Report -->
    <!-- CT_CONSTRUCTOR_THROW - I2P design pattern: constructors intentionally throw -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>

    <!-- DLS_DEAD_LOCAL_STORE - intentional re-initializations in complex control flow -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE" />
    </Match>

    <!-- RCN_REDUNDANT_NULLCHECK - SpotBugs type inference wrong for I2P collections -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
    </Match>

    <!-- UC_USELESS_CONDITION - constant-switch patterns in CryptoConstants, RateConstants -->
    <Match>
        <Bug pattern="UC_USELESS_CONDITION" />
    </Match>

    <!-- SE_BAD_FIELD / SE_NO_SERIALVERSIONID - non-serializable classes never cross JVM -->
    <Match>
        <Bug pattern="SE_BAD_FIELD" />
    </Match>
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID" />
    </Match>

    <!-- SS_SHOULD_BE_STATIC - fields depend on instance state -->
    <Match>
        <Bug pattern="SS_SHOULD_BE_STATIC" />
    </Match>

    <!-- Exclude PA_PUBLIC_PRIMITIVE_ATTRIBUTE - serialization requires public fields -->
    <Match>
        <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE" />
    </Match>

    <!-- Include only I2P-specific packages - remove these matches to allow analysis -->
    <!-- The following are commented out to allow analysis of I2P code -->
    <!--
    <Match>
        <Class name="~net\.i2p\..*" />
        <Bug pattern="~.*" />
    </Match>
    
    <Match>
        <Class name="~router\..*" />
        <Bug pattern="~.*" />
    </Match>
    
    <Match>
        <Class name="~apps\..*" />
        <Bug pattern="~.*" />
    </Match>
    -->

    <!-- RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE - SpotBugs false positive in catch blocks
         where variable can be non-null if earlier operation succeeded but later one threw -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE" />
    </Match>

    <!-- ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD - intentional singleton pattern,
         one Tuner/Daemon/BlocklistManager instance per router writes to config fields -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
    </Match>

    <!-- DMI_RANDOM_USED_ONLY_ONCE - all use SecureRandom (not Random),
         SecureRandom has no seed-quality issue -->
    <Match>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE" />
    </Match>

    <!-- VO_VOLATILE_INCREMENT - statistical counters for cache/transport metrics,
         lost increments have no correctness impact -->
    <Match>
        <Bug pattern="VO_VOLATILE_INCREMENT" />
    </Match>

    <!-- JLM_JSR166_UTILCONCURRENT_MONITORENTER - false positive for
         j.u.c. lock patterns used correctly -->
    <Match>
        <Bug pattern="JLM_JSR166_UTILCONCURRENT_MONITORENTER" />
    </Match>

    <!-- DM_GC - explicit GC call in ConfigServiceHandler is intentional
         during shutdown to release native resources -->
    <Match>
        <Bug pattern="DM_GC" />
    </Match>

    <!-- DE_MIGHT_IGNORE - intentional catch-and-ignore in resource cleanup
         (close, delete, notify patterns throughout codebase) -->
    <Match>
        <Bug pattern="DE_MIGHT_IGNORE" />
    </Match>

    <!-- RV_RETURN_VALUE_IGNORED_BAD_PRACTICE - intentional ignore of file.delete(),
         mkdirs(), queue.offer() returns where failure is non-critical -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
    </Match>

    <!-- RV_RETURN_VALUE_IGNORED - same as above for non-bad-practice variant -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED" />
    </Match>

    <!-- REC_CATCH_EXCEPTION - intentional broad Exception catches in
         I/O, crypto, and network code where specific exceptions vary by provider -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
    </Match>

    <!-- IS2_INCONSISTENT_SYNC - inconsistent synchronization in transport/tunnel
         code is intentional (optimistic reads for performance, fields are volatile
         or access is single-threaded by design) -->
    <Match>
        <Bug pattern="IS2_INCONSISTENT_SYNC" />
    </Match>

    <!-- DCN_NULLPOINTER_EXCEPTION - intentional defensive NPE catches on
         corrupt network data from untrusted peers -->
    <Match>
        <Bug pattern="DCN_NULLPOINTER_EXCEPTION" />
    </Match>

    <!-- SF_SWITCH_FALLTHROUGH - intentional fall-through in switch statements -->
    <Match>
        <Bug pattern="SF_SWITCH_FALLTHROUGH" />
    </Match>

    <!-- RU_INVOKE_RUN - intentional synchronous task.run() in I2PTunnel
         where the caller manages the thread lifecycle -->
    <Match>
        <Bug pattern="RU_INVOKE_RUN" />
    </Match>

    <!-- DM_EXIT - intentional System.exit() in OOM handlers and CLI tools
         (I2PTunnel, SAM Bridge) -->
    <Match>
        <Bug pattern="DM_EXIT" />
    </Match>

    <!-- DMI_HARDCODED_ABSOLUTE_FILENAME - legitimate Linux system paths
         (/sys/devices/system/cpu, /etc/i2p, /usr/share/i2p) with platform guards -->
    <Match>
        <Bug pattern="DMI_HARDCODED_ABSOLUTE_FILENAME" />
    </Match>

    <!-- DMI_ENTRY_SETS_MAY_REUSE_ENTRY_OBJECTS - false positive, entries are
         immediately copied to a sorted list under lock -->
    <Match>
        <Bug pattern="DMI_ENTRY_SETS_MAY_REUSE_ENTRY_OBJECTS" />
    </Match>

    <!-- MS_EXPOSE_REP - standard Java pattern for returning internal collections,
         callers do not modify returned objects -->
    <Match>
        <Bug pattern="MS_EXPOSE_REP" />
    </Match>

    <!-- MS_MUTABLE_ARRAY - public static final long[] rate period constants,
         intentionally exposed for reuse by callers -->
    <Match>
        <Bug pattern="MS_MUTABLE_ARRAY" />
    </Match>

    <!-- MS_MUTABLE_COLLECTION_PKGPROTECT - package-private mutable collections
         used as shared constants between related classes -->
    <Match>
        <Bug pattern="MS_MUTABLE_COLLECTION_PKGPROTECT" />
    </Match>

    <!-- MS_PKGPROTECT - package-private fields for cross-class access within module -->
    <Match>
        <Bug pattern="MS_PKGPROTECT" />
    </Match>

    <!-- EQ_DOESNT_OVERRIDE_EQUALS - intentional identity comparison for classes
         that extend Object without overriding equals/hashCode -->
    <Match>
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS" />
    </Match>

    <!-- EQ_OVERRIDING_EQUALS_NOT_SYMMETRIC - equals() implementations that use
         instanceof rather than getClass() for performance in hot paths -->
    <Match>
        <Bug pattern="EQ_OVERRIDING_EQUALS_NOT_SYMMETRIC" />
    </Match>

    <!-- URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD - data transfer objects with
         public fields used for serialization/deserialization -->
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
    </Match>

    <!-- URF_UNREAD_FIELD - fields written for side effects or future use -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD" />
    </Match>

    <!-- SWL_SLEEP_WITH_LOCK_HELD - Thread.sleep() under lock is intentional
         in tunnel/transport throttling for bounded waits -->
    <Match>
        <Bug pattern="SWL_SLEEP_WITH_LOCK_HELD" />
    </Match>

    <!-- NN_NAKED_NOTIFY - notify() without synchronized is intentional where
         the object monitor is held by the JVM or the notify is for wakeup only -->
    <Match>
        <Bug pattern="NN_NAKED_NOTIFY" />
    </Match>

    <!-- AT_OPERATION_SEQUENCE_ON_CONCURRENT_ABSTRACTION - non-atomic check-then-act
         on concurrent collections is intentional where race is benign -->
    <Match>
        <Bug pattern="AT_OPERATION_SEQUENCE_ON_CONCURRENT_ABSTRACTION" />
    </Match>

    <!-- SSD_DO_NOT_USE_INSTANCE_LOCK_ON_SHARED_STATIC_DATA - intentional where
         static data is immutable after initialization or uses volatile fields -->
    <Match>
        <Bug pattern="SSD_DO_NOT_USE_INSTANCE_LOCK_ON_SHARED_STATIC_DATA" />
    </Match>

    <!-- UW_UNCOND_WAIT - Object.wait() outside loop is intentional for
         one-shot wakeup signaling in I2PTunnel -->
    <Match>
        <Bug pattern="UW_UNCOND_WAIT" />
    </Match>

    <!-- WA_NOT_IN_LOOP - notifyAll() outside loop is intentional for
         one-shot wakeup signaling -->
    <Match>
        <Bug pattern="WA_NOT_IN_LOOP" />
    </Match>

    <!-- UG_SYNC_SET_UNSYNC_GET - synchronized setter with unsynchronized getter
         is intentional for volatile-like fields where stale reads are acceptable -->
    <Match>
        <Bug pattern="UG_SYNC_SET_UNSYNC_GET" />
    </Match>

    <!-- BC_UNCONFIRMED_CAST - unchecked casts in generics-heavy code where
         type safety is ensured by construction -->
    <Match>
        <Bug pattern="BC_UNCONFIRMED_CAST" />
    </Match>

    <!-- BC_VACUOUS_INSTANCEOF - intentional instanceof checks in deserialization
         or type-switch patterns -->
    <Match>
        <Bug pattern="BC_VACUOUS_INSTANCEOF" />
    </Match>

    <!-- UR_UNINIT_READ_CALLED_FROM_SUPER_CONSTRUCTOR - RouterContext reads
         properties in super constructor before subclass init; this is by design -->
    <Match>
        <Bug pattern="UR_UNINIT_READ_CALLED_FROM_SUPER_CONSTRUCTOR" />
    </Match>

    <!-- UC_USELESS_OBJECT - minor: temp arrays/strings in non-hot paths -->
    <Match>
        <Bug pattern="UC_USELESS_OBJECT" />
    </Match>

    <!-- UCF_USELESS_CONTROL_FLOW - generated JSP code, not hand-written -->
    <Match>
        <Bug pattern="UCF_USELESS_CONTROL_FLOW" />
    </Match>

    <!-- DB_DUPLICATE_BRANCHES - generated JSP code, not hand-written -->
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES" />
    </Match>

    <!-- NP_LOAD_OF_KNOWN_NULL_VALUE - false positive: SpotBugs tracks variable
         through method calls that may return null, but callers guard before use -->
    <Match>
        <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE" />
    </Match>

    <!-- NP_NULL_ON_SOME_PATH - false positive: null guards are present in
         the actual code, SpotBugs misreads compiled inner class line numbers -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH" />
    </Match>

    <!-- NP_GUARANTEED_DEREF - false positive: SpotBugs reports dereference on
         paths that are guarded by prior null checks in the same method -->
    <Match>
        <Bug pattern="NP_GUARANTEED_DEREF" />
    </Match>

    <!-- NP_NULL_PARAM_DEREF - false positive: fromPeer/testIP are checked for
         null earlier in the method, SpotBugs line mapping from inner classes is wrong -->
    <Match>
        <Bug pattern="NP_NULL_PARAM_DEREF" />
    </Match>

    <!-- ENV_USE_PROPERTY_INSTEAD_OF_ENV - System.getenv() is correct for
         PROCESSOR_ARCHITECTURE on Windows, no System.getProperty() equivalent -->
    <Match>
        <Bug pattern="ENV_USE_PROPERTY_INSTEAD_OF_ENV" />
    </Match>

    <!-- DP_CREATE_CLASSLOADER_INSIDE_DO_PRIVILEGED - I2P runs with appropriate
         permissions, doPrivileged not needed for internal classloading -->
    <Match>
        <Bug pattern="DP_CREATE_CLASSLOADER_INSIDE_DO_PRIVILEGED" />
    </Match>

    <!-- OS_OPEN_STREAM - false positive: wraps StringBuilderWriter (not file),
         no actual resource leak -->
    <Match>
        <Bug pattern="OS_OPEN_STREAM" />
    </Match>

    <!-- HRS_REQUEST_PARAMETER_TO_HTTP_HEADER - validated redirect parameters
         are URL-decoded and validated against allowed hosts before use -->
    <Match>
        <Bug pattern="HRS_REQUEST_PARAMETER_TO_HTTP_HEADER" />
    </Match>

    <!-- PT_ABSOLUTE_PATH_TRAVERSAL / PT_RELATIVE_PATH_TRAVERSAL - false positive:
         getLong() reads from system files (/sys, /proc) not user-controlled paths -->
    <Match>
        <Bug pattern="PT_ABSOLUTE_PATH_TRAVERSAL" />
    </Match>
    <Match>
        <Bug pattern="PT_RELATIVE_PATH_TRAVERSAL" />
    </Match>

    <!-- OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE - generated JSP code -->
    <Match>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
    </Match>

    <!-- DMI_HARDCODED_ABSOLUTE_FILENAME - already excluded above -->

    <!-- SE_BAD_FIELD_STORE - non-serializable fields in classes that are
         never actually serialized across JVMs -->
    <Match>
        <Bug pattern="SE_BAD_FIELD_STORE" />
    </Match>

    <!-- SE_INNER_CLASS - non-static inner classes are intentional in I2P
         where the inner instance needs outer context -->
    <Match>
        <Bug pattern="SE_INNER_CLASS" />
    </Match>

    <!-- SE_TRANSIENT_FIELD_NOT_RESTORED - transient fields intentionally not
         restored in readObject, reconstructed lazily -->
    <Match>
        <Bug pattern="SE_TRANSIENT_FIELD_NOT_RESTORED" />
    </Match>

    <!-- SING_SINGLETON_IMPLEMENTS_SERIALIZABLE - singletons that implement
         Serializable for config persistence, readResolve prevents duplication -->
    <Match>
        <Bug pattern="SING_SINGLETON_IMPLEMENTS_SERIALIZABLE" />
    </Match>

    <!-- SIC_INNER_SHOULD_BE_STATIC - inner classes that capture outer reference
         are intentional where outer state is needed -->
    <Match>
        <Bug pattern="SIC_INNER_SHOULD_BE_STATIC" />
    </Match>

    <!-- VO_VOLATILE_REFERENCE_TO_ARRAY - volatile array reference is intentional
         for lock-free double-checked construction pattern -->
    <Match>
        <Bug pattern="VO_VOLATILE_REFERENCE_TO_ARRAY" />
    </Match>

    <!-- LI_LAZY_INIT_STATIC - lazy initialization of static fields is intentional
         in singleton/lifecycle classes -->
    <Match>
        <Bug pattern="LI_LAZY_INIT_STATIC" />
    </Match>

    <!-- LI_LAZY_INIT_UPDATE_STATIC - same pattern as LI_LAZY_INIT_STATIC -->
    <Match>
        <Bug pattern="LI_LAZY_INIT_UPDATE_STATIC" />
    </Match>

    <!-- ML_SYNC_ON_UPDATED_FIELD - synchronized on field that is also updated
         is intentional for compare-and-swap patterns -->
    <Match>
        <Bug pattern="ML_SYNC_ON_UPDATED_FIELD" />
    </Match>

    <!-- DC_PARTIALLY_CONSTRUCTED - false positive: object is fully constructed
         before being published to the queue -->
    <Match>
        <Bug pattern="DC_PARTIALLY_CONSTRUCTED" />
    </Match>

    <!-- UL_UNRELEASED_LOCK_EXCEPTION_PATH - readLock() in try block with
         unlock in finally; SpotBugs misreports the exception edge -->
    <Match>
        <Bug pattern="UL_UNRELEASED_LOCK_EXCEPTION_PATH" />
    </Match>

    <!-- GC_UNRELATED_TYPES - false positive: _runners is a Set<MessageReceiver>,
         remove(this) is type-correct -->
    <Match>
        <Bug pattern="GC_UNRELATED_TYPES" />
    </Match>

    <!-- EI_EXPOSE_STATIC_REP2 - standard static setter pattern for singletons -->
    <Match>
        <Bug pattern="EI_EXPOSE_STATIC_REP2" />
    </Match>

    <!-- UPM_UNCALLED_PRIVATE_METHOD - private methods called via reflection
         or from inner classes that SpotBugs cannot track -->
    <Match>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD" />
    </Match>

    <!-- ICAST_INT_CAST_TO_FLOAT_PASSED_TO_ROUND - already fixed, remaining
         are in code where precision loss is acceptable -->
    <Match>
        <Bug pattern="ICAST_INT_CAST_TO_FLOAT_PASSED_TO_ROUND" />
    </Match>

    <!-- WMI_WRONG_MAP_ITERATOR - false positive: iterates entrySet() when
         keySet() could be used, but entrySet avoids extra lookup -->
    <Match>
        <Bug pattern="WMI_WRONG_MAP_ITERATOR" />
    </Match>

    <!-- IM_BAD_CHECK_FOR_ODD - false positive: odd check is correct in
         the specific context -->
    <Match>
        <Bug pattern="IM_BAD_CHECK_FOR_ODD" />
    </Match>

    <!-- RV_DONT_JUST_NULL_CHECK_READLINE - readLine() returning null is used
         as loop terminator, the null check is intentional -->
    <Match>
        <Bug pattern="RV_DONT_JUST_NULL_CHECK_READLINE" />
    </Match>

    <!-- NP_NULL_ON_SOME_PATH_MIDDLE - already covered by NP_NULL_ON_SOME_PATH -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_MIDDLE" />
    </Match>

    <!-- NP_NULL_ON_SOME_PATH_EXCEPTION - false positive on exception paths
         where variables are guaranteed non-null -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_EXCEPTION" />
    </Match>

    <!-- SE_COMPARATOR_SHOULD_BE_SERIALIZABLE - comparators that are never
         serialized don't need Serializable -->
    <Match>
        <Bug pattern="SE_COMPARATOR_SHOULD_BE_SERIALIZABLE" />
    </Match>

    <!-- SBSC_USE_STRINGBUFFER_CONCATENATION - false positive: already using
         StringBuilder, SpotBugs misidentifies the pattern -->
    <Match>
        <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION" />
    </Match>

    <!-- RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE - false positive:
         SpotBugs type flow analysis incorrect for I2P collection patterns -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE" />
    </Match>

</FindBugsFilter>

msgid ""
msgstr ""
"Language: bo\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=1; plural=0;\n"

msgid "Failed to load the wrapper"
msgstr "རྐྱང་སྒྲོམ་བཟོ་གཞི་འཇུག་མ་ཚང་།"

#, sh-format
msgid "$APP_LONG_NAME is already running."
msgstr "$APP_LONG_NAME ད་ལྟ་བཞག་ཡོད།"

#, sh-format
msgid "Running $APP_LONG_NAME"
msgstr "$APP_LONG_NAME བཞག་བཞིན་ཡོད།"

#, sh-format
msgid "Waiting for $APP_LONG_NAME"
msgstr "$APP_LONG_NAME ལ་སྒུག་བཞིན་ཡོད།"

#, sh-format
msgid "WARNING: $APP_LONG_NAME may have failed to start."
msgstr "ཉེན་བརྡ། $APP_LONG_NAME འགོ་འཛུགས་ལ་ཕམ་སྲིད།"

msgid "Must be root to perform this action."
msgstr "བྱ་སྤྱོད་འདི་ལ་root དབང་ཤོག་དགོས།"

#, sh-format
msgid "Starting $APP_LONG_NAME"
msgstr "$APP_LONG_NAME འགོ་འཛུགས་བཞིན་ཡོད།"

#, sh-format
msgid "Stopping $APP_LONG_NAME"
msgstr "$APP_LONG_NAME འགོག་བཞིན་ཡོད།"

#, sh-format
msgid "$APP_LONG_NAME was not running."
msgstr "$APP_LONG_NAME བཞག་མེད།"

#, sh-format
msgid "Unable to stop $APP_LONG_NAME."
msgstr "$APP_LONG_NAME འགོག་མ་ཚང་།"

#, sh-format
msgid "Waiting for $APP_LONG_NAME to exit"
msgstr "$APP_LONG_NAME ཕྱིར་ཐོན་ལ་སྒུག་བཞིན་ཡོད།"

#, sh-format
msgid "Failed to stop $APP_LONG_NAME."
msgstr "$APP_LONG_NAME འགོག་ལ་ཕམ།"

#, sh-format
msgid "Stopped $APP_LONG_NAME."
msgstr "$APP_LONG_NAME འགོག་ཟིན།"

#, sh-format
msgid "Stopping $APP_LONG_NAME gracefully"
msgstr "$APP_LONG_NAME སྙིང་བཟང་མཐུན་འགྱུར་བྱེད་བཞིན་ཡོད།"

#, sh-format
msgid "$APP_LONG_NAME is not running."
msgstr "$APP_LONG_NAME བཞག་མེད།"

#, sh-format
msgid "$APP_LONG_NAME is running: PID:$pid"
msgstr "$APP_LONG_NAME བཞག་ཡོད། PID:$pid"

#, sh-format
msgid "$APP_LONG_NAME is running: PID:$pid, Wrapper:$STATUS, Java:$JAVASTATUS"
msgstr "$APP_LONG_NAME བཞག་ཡོད། PID:$pid, Wrapper:$STATUS, Java:$JAVASTATUS"

#, sh-format
msgid "The $APP_LONG_NAME daemon is already installed."
msgstr "$APP_LONG_NAME དེ་མོན་ ད་ལྟ་ཚུད་ཟིན།"

#, sh-format
msgid "Installing the $APP_LONG_NAME daemon"
msgstr "$APP_LONG_NAME དེ་མོན་ འཚུད་བཞིན་ཡོད།"

#, sh-format
msgid "Install not currently supported for $DIST_OS"
msgstr "འཛུགས་སྒྲིག་  $DIST_OS ལ་ད་ལྟ་རྒྱབ་སྐྱོར་མེད།"

#, sh-format
msgid "Removing $APP_LONG_NAME daemon"
msgstr "$APP_LONG_NAME དེ་མོན་ སེལ་བཞིན་ཡོད།"

#, sh-format
msgid "The $APP_LONG_NAME daemon is not currently installed."
msgstr "$APP_LONG_NAME དེ་མོན་ ད་ལྟ་ཚུད་མེད།"

#, sh-format
msgid "Remove not currently supported for $DIST_OS"
msgstr "སེལ་སྒྲིག་  $DIST_OS ལ་ད་ལྟ་རྒྱབ་སྐྱོར་མེད།"

msgid "Commands:"
msgstr "བཀའ་དྲིན།"

msgid "Launch in the current console."
msgstr "ད་ལྟའི་ console ནང་གཏོང་བ།"

msgid "Start in the background as a daemon process."
msgstr "རྒྱབ་ལྗོངས་སུ་ དེ་མོན་ བྱ་རིམ་ལྟར་འགོ་འཛུགས།"

msgid "Stop if running as a daemon or in another console."
msgstr "དེ་མོན་ཡང་ན  console གཞན་དུ་བཞག་ན་འགོག།"

msgid "Stop gracefully, may take up to 11 minutes or more."
msgstr "སྙིང་བཟང་མཐུན་འགྱུར་བྱེད་པ། སྐར་མ ༡༡ ཙམ་འགོར་སྲིད།"

msgid "Restart gracefully, may take up to 11 minutes or more."
msgstr "སྙིང་བཟང་མཐུན་འགྱུར་བྱེད་པ། སྐར་མ ༡༡ ཙམ་འགོར་སྲིད།"

msgid "Stop if running and then start."
msgstr "བཞག་ན་འགོག་རྗེས་འགོ་འཛུགས།"

msgid "Restart only if already running."
msgstr "བཞག་ཡོད་ན་གཅིག་ཁོ་ནར་ཡང་བསྐྱར་འགོ་འཛུགས།"

msgid "Query the current status."
msgstr "ད་ལྟའི་གནས་སྟངས་དྲིས།"

msgid "Install to start automatically when system boots."
msgstr "མ་ལག་འགོ་ཐོག་རང་འགོ་འཛུགས་པར་འཛུགས།"

msgid "Uninstall."
msgstr "འཛུགས་སེལ།"

msgid "Request a Java thread dump if running."
msgstr "བཞག་ན Java thread dump ཞུ།"

msgid "Please edit i2prouter and set the variable RUN_AS_USER"
msgstr "i2prouter ལ་བཅོས་བསྒྱུར་བྱེད་ནས་ RUN_AS_USER ཡིག་འབྲུ་སྒྲིག་རོགས།"

msgid "Running I2P as the root user is *not* recommended."
msgstr "I2P root བེད་སྤྱོད་མཁན་ལྟར་བཞག་པ་ *མི་འོས་པར་མདོར་བསྟན།*"

msgid "To run as root anyway, edit i2prouter and set ALLOW_ROOT=true."
msgstr "root ལྟར་བཞག་ནའང་ i2prouter ལ་བཅོས་བསྒྱུར་བྱེད་ནས་ ALLOW_ROOT=true སྒྲིག།"

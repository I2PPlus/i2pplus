# NOTE: This I2P config file must use UTF-8 encoding
# Minimal installation overrides
i2np.bandwidth.inboundBurstKBytes=5630
i2np.bandwidth.inboundBurstKBytesPerSecond=32
i2np.bandwidth.inboundKBytesPerSecond=32
i2np.bandwidth.outboundBurstKBytes=5630
i2np.bandwidth.outboundBurstKBytesPerSecond=32
i2np.bandwidth.outboundKBytesPerSecond=32
i2np.ntcp.autoip=true
i2np.ntcp.enable=true
i2np.udp.addressSources=local,upnp,ssu
i2np.upnp.enable=true
router.inboundPool.length=2
router.inboundPool.lengthVariance=0
router.outboundPool.length=2
router.outboundPool.lengthVariance=0
router.maxParticipatingTunnels=50
router.sharePercentage=80
stat.full=false
stat.summaries=none

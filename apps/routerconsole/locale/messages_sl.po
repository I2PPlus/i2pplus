msgstr "Integrirajte stanje I2P v širše spremljanje omrežja"

#: /tmp/build-i2p/apps/routerconsole/java/build/../../jsp/WEB-INF/classes/net/i2p/router/web/jsp/help/jsonrpc_jsp.java:793
msgid "Alerting systems:"
msgstr "Sistemi za opozarjanje:"

#: /tmp/build-i2p/apps/routerconsole/java/build/../../jsp/WEB-INF/classes/net/i2p/router/web/jsp/help/jsonrpc_jsp.java:795
msgid "Send notifications based on router status changes"
msgstr "Pošljite obvestila na podlagi sprememb stanja usmerjevalnika"

#: /tmp/build-i2p/apps/routerconsole/java/build/../../jsp/WEB-INF/classes/net/i2p/router/web/jsp/help/legal_jsp.java:315
msgid "Licensing Information"
msgstr "Informacije o licenci"

#: /tmp/build-i2p/apps/routerconsole/java/build/../../jsp/WEB-INF/classes/net/i2p/router/web/jsp/help/legal_jsp.java:405

#, java-format
msgid "To change client options, edit the file: {0}"
msgstr "ক্লায়েন্ট বিকল্প পরিবর্তন করতে, ফাইলটি সম্পাদনা করুন: {0}"

msgid ""
"Be careful changing any settings here. The 'router console' and 'application"
" tunnels' are required for most uses of I2P. Only advanced users should "
"change these."
msgstr ""
"এখানে যেকোনো সেটিংস পরিবর্তনে সতর্ক থাকুন। I2P-এর অধিকাংশ ব্যবহারের জন্য "
"''router console'' এবং ''application tunnels'' প্রয়োজন। শুধুমাত্র উন্নত "
"ব্যবহারকারীদের এগুলি পরিবর্তন করা উচিত।"

msgid "config router family"
msgstr "রাউটার ফ্যামিলি কনফিগারেশন"

msgid "Routers in the same family share a family key."
msgstr "একই ফ্যামিলির রাউটারগুলি একটি ফ্যামিলি কী ভাগ করে নেয়।"

msgid ""
"To join an existing family, import the private key you exported from a "
"router in the family."
msgstr ""
"বিদ্যমান ফ্যামিলিতে যোগ দিতে, ফ্যামিলির একটি রাউটার থেকে আপনি যেই প্রাইভেট "
"কী এক্সপোর্ট করেছেন তা ইম্পোর্ট করুন।"

msgid "To start a new family, enter a family name."
msgstr "নতুন ফ্যামিলি শুরু করতে, একটি ফ্যামিলি নাম লিখুন।"

msgid "Join Existing Router Family"
msgstr "বিদ্যমান রাউটার ফ্যামিলিতে যোগ দিন"

msgid ""
"Import the secret family key that you exported from an existing router in "
"the family."
msgstr ""
"ফ্যামিলির একটি বিদ্যমান রাউটার থেকে আপনি যে গোপন ফ্যামিলি কী এক্সপোর্ট "
"করেছেন তা ইম্পোর্ট করুন।"

msgid "Select secret key file"
msgstr "গোপন কী ফাইল নির্বাচন করুন"

msgid "Create New Router Family"
msgstr "নতুন রাউটার ফ্যামিলি তৈরি করুন"

msgid ""
"You may create a new router family here. Once you have created the family, "
"you may export the family key file and share with other routers in your "
"nominated family."
msgstr ""
"আপনি এখানে একটি নতুন রাউটার ফ্যামিলি তৈরি করতে পারেন। ফ্যামিলি তৈরি করার "
"পরে, আপনি ফ্যামিলি কী ফাইল এক্সপোর্ট করে আপনার মনোনীত ফ্যামিলির অন্যান্য "
"রাউটারের সাথে ভাগ করে নিতে পারেন।"

msgid ""
"Note: To avoid deanonymization, do not name your family with personally-"
"attributable information e.g. your IRC nickname; your family name is "
"associated with your router's IP address."
msgstr ""
"নোট: ডিনonymization এড়াতে, আপনার ফ্যামিলিকে ব্যক্তিগতভাবে চিহ্নিতযোগ্য তথ্য"
" যেমন আপনার IRC ডাকনাম দিয়ে নামকরণ করবেন না; আপনার ফ্যামিলি নাম আপনার "
"রাউটারের IP ঠিকানার সাথে যুক্ত।"

msgid "Enter new family name"
msgstr "নতুন ফ্যামিলি নাম লিখুন"

msgid "Export Family Key"
msgstr "ফ্যামিলি কী এক্সপোর্ট করুন"

msgid ""
"Export the secret family key to be imported into other routers you control."
msgstr ""
"আপনার নিয়ন্ত্রণাধীন অন্যান্য রাউটারে ইম্পোর্ট করার জন্য গোপন ফ্যামিলি কী "
"এক্সপোর্ট করুন।"

#, java-format
msgid "Restart required to activate family {0}."
msgstr "ফ্যামিলি {0} সক্রিয় করতে পুনরায় চালু প্রয়োজন।"

msgid "After restarting, you may export the family key."
msgstr "পুনরায় চালু করার পরে, আপনি ফ্যামিলি কী এক্সপোর্ট করতে পারেন।"

msgid "Leave Router Family"
msgstr "রাউটার ফ্যামিলি ত্যাগ করুন"

#, java-format
msgid "No longer be a member of the family {0}."
msgstr "ফ্যামিলি {0}-এর больше সদস্য থাকবেন না।"

msgid "config home"
msgstr "হোম কনফিগারেশন"

msgid "Homepage Customization"
msgstr "হোমপেজ কাস্টমাইজেশন"

msgid "Search Engines"
msgstr "সার্চ ইঞ্জিন"

msgid "Applications and Configuration"
msgstr "অ্যাপ্লিকেশন এবং কনফিগারেশন"

msgid "Sites of Interest"
msgstr "আগ্রহের সাইট"

msgid "config i2cp"
msgstr "I2CP কনফিগারেশন"

msgid "External Client Access"
msgstr "বহিরাগত ক্লায়েন্ট অ্যাক্সেস"

msgid "The default settings will work for most people."
msgstr "ডিফল্ট সেটিংস অধিকাংশ মানুষের জন্য কাজ করবে।"

msgid "Any changes made here must also be configured in the external client."
msgstr "এখানে করা যেকোনো পরিবর্তন বহিরাগত ক্লায়েন্টেও কনফিগার করতে হবে।"

msgid "Many clients do not support SSL or authorization."
msgstr "অনেক ক্লায়েন্ট SSL বা অনুমোদন সমর্থন করে না।"

msgid "All changes require restart to take effect."
msgstr "সমস্ত পরিবর্তন কার্যকর হতে পুনরায় চালু প্রয়োজন।"

msgid "External I2P Client Protocol (I2CP) Interface Access"
msgstr "বহিরাগত I2P ক্লায়েন্ট প্রোটোকল (I2CP) ইন্টারফেস অ্যাক্সেস"

msgid "Enabled without SSL"
msgstr "SSL ছাড়া সক্রিয়"

msgid "Enabled with SSL required"
msgstr "SSL প্রয়োজন সহ সক্রিয়"

msgid "Disabled - Clients outside this Java process may not connect"
msgstr ""
"নিষ্ক্রিয় - এই Java প্রক্রিয়ার বাইরের ক্লায়েন্টরা সংযোগ করতে পারবে না"

msgid "I2CP Interface"
msgstr "I2CP ইন্টারফেস"

msgid "I2CP Port"
msgstr "I2CP পোর্ট"

msgid "Require username and password"
msgstr "ব্যবহারকারী নাম এবং পাসওয়ার্ড প্রয়োজন"

msgid "config keyring"
msgstr "কিরিং কনফিগারেশন"

msgid "Keyring Manager"
msgstr "কিরিং ব্যবস্থাপক"

msgid "The router keyring is used to decrypt encrypted LeaseSets."
msgstr "রাউটার কিরিং এনক্রিপ্টেড লিজসেট ডিক্রিপ্ট করতে ব্যবহৃত হয়।"

msgid ""
"The keyring may contain keys for local or remote encrypted destinations."
msgstr ""
"কিরিংয়ে স্থানীয় বা দূরবর্তী এনক্রিপ্টেড গন্তব্যের জন্য কী থাকতে পারে।"

msgid "Manual Keyring Addition"
msgstr "ম্যানুয়াল কিরিং সংযোজন"

msgid "Enter keys for encrypted remote destinations here."
msgstr "এখানে এনক্রিপ্টেড দূরবর্তী গন্তব্যের জন্য কী লিখুন।"

msgid ""
"Keys for local destinations must be entered on the configuration page for "
"the relevant service in the"
msgstr ""
"স্থানীয় গন্তব্যের জন্য কী প্রাসঙ্গিক পরিষেবার কনফিগারেশন পৃষ্ঠায় প্রবেশ "
"করাতে হবে"

msgid "Full destination, name, Base32, or hash"
msgstr "সম্পূর্ণ গন্তব্য, নাম, Base32, বা হ্যাশ"

msgid "Enter key provided by server operator."
msgstr "সার্ভার অপারেটরের দেওয়া কী লিখুন।"

msgid "Prevents server discovery by floodfills"
msgstr "Floodfill দ্বারা সার্ভার আবিষ্কার প্রতিরোধ করে"

msgid "Enter password provided by server operator."
msgstr "সার্ভার অপারেটরের দেওয়া পাসওয়ার্ড লিখুন।"

msgid "Enter key and password provided by server operator."
msgstr "সার্ভার অপারেটরের দেওয়া কী এবং পাসওয়ার্ড লিখুন।"

msgid "Key will be generated."
msgstr "কী তৈরি করা হবে।"

msgid "Leave blank for DH, will be generated automatically"
msgstr "DH-এর জন্য খালি রাখুন, স্বয়ংক্রিয়ভাবে তৈরি হবে"

msgid "Optional lookup password"
msgstr "ঐচ্ছিক লুকআপ পাসওয়ার্ড"

msgid "Set password required to access this service"
msgstr "এই পরিষেবা অ্যাক্সেস করতে প্রয়োজনীয় পাসওয়ার্ড সেট করুন"

msgid "config logging"
msgstr "লগিং কনফিগারেশন"

msgid "Configure I2P Logging Options"
msgstr "I2P লগিং বিকল্প কনফিগার করুন"

msgid "View Router Logs"
msgstr "রাউটার লগ দেখুন"

msgid "View Logs"
msgstr "লগ দেখুন"

msgid "Log file"
msgstr "লগ ফাইল"

#, java-format
msgid "Edit {0} to change"
msgstr "পরিবর্তন করতে {0} সম্পাদনা করুন"

msgid "(the symbol '@' will be replaced during log rotation)"
msgstr "(লগ রোটেশনের সময় ''@'' চিহ্নটি প্রতিস্থাপিত হবে)"

msgid "Log record format"
msgstr "লগ রেকর্ড ফরম্যাট"

msgid ""
"(use 'd' = date, 'c' = class, 't' = thread, 'p' = priority, 'm' = message)"
msgstr ""
"(''d'' = তারিখ, ''c'' = ক্লাস, ''t'' = থ্রেড, ''p'' = অগ্রাধিকার, ''m'' = "
"বার্তা)"

msgid "Log date format"
msgstr "লগ তারিখ ফরম্যাট"

msgid ""
"('MM' = month, 'dd' = day, 'HH' = hour, 'mm' = minute, 'ss' = second, 'SSS' "
"= millisecond)"
msgstr ""
"(''MM'' = মাস, ''dd'' = দিন, ''HH'' = ঘন্টা, ''mm'' = মিনিট, ''ss'' = "
"সেকেন্ড, ''SSS'' = মিলিসেকেন্ড)"

msgid "Max log file size"
msgstr "সর্বোচ্চ লগ ফাইল আকার"

msgid "GZIP Compression"
msgstr "GZIP কম্প্রেশন"

msgid "Default log level"
msgstr "ডিফল্ট লগ স্তর"

msgid ""
"(DEBUG and INFO are not recommended defaults, as they will drastically slow "
"down your router)"
msgstr ""
"(DEBUG এবং INFO ডিফল্ট হিসেবে সুপারিশ করা হয় না, কারণ এগুলি আপনার রাউটারকে "
"মারাত্মকভাবে ধীর করে দেবে)"

msgid "Log level overrides"
msgstr "লগ স্তর ওভাররাইড"

msgid "New override"
msgstr "নতুন ওভাররাইড"

msgid "config networking"
msgstr "নেটওয়ার্কিং কনফিগারেশন"

msgid "Network Configuration"
msgstr "নেটওয়ার্ক কনফিগারেশন"

msgid "IP and Transport Configuration"
msgstr "IP এবং ট্রান্সপোর্ট কনফিগারেশন"

msgid "Help with router configuration"
msgstr "রাউটার কনফিগারেশনে সহায়তা"

msgid "Configuration Help"
msgstr "কনফিগারেশন সহায়তা"

msgid "Changing these settings will restart your router."
msgstr "এই সেটিংস পরিবর্তন করলে আপনার রাউটার পুনরায় চালু হবে।"

msgid "IP Configuration"
msgstr "IP কনফিগারেশন"

msgid "Externally reachable hostname or IP address"
msgstr "বাহ্যিকভাবে অ্যাক্সেসযোগ্য হোস্টনেম বা IP ঠিকানা"

msgid "Use all auto-detect methods"
msgstr "সমস্ত স্বয়ং-শনাক্তকরণ পদ্ধতি ব্যবহার করুন"

msgid "Disable UPnP IP address detection"
msgstr "UPnP IP ঠিকানা শনাক্তকরণ নিষ্ক্রিয় করুন"

msgid "Ignore local interface IP address"
msgstr "স্থানীয় ইন্টারফেস IP ঠিকানা উপেক্ষা করুন"

msgid "Use SSU IP address detection only"
msgstr "শুধুমাত্র SSU IP ঠিকানা শনাক্তকরণ ব্যবহার করুন"

msgid "Enabling this mode will prevent participating traffic"
msgstr "এই মোড সক্রিয় করলে অংশগ্রহণকারী ট্রাফিক প্রতিরোধ হবে"

msgid "Hidden mode - do not publish IP address to NetDB"
msgstr "লুকানো মোড - NetDB-তে IP ঠিকানা প্রকাশ করবেন না"

msgid "Specify hostname or IP address"
msgstr "হোস্টনেম বা IP ঠিকানা নির্দিষ্ট করুন"

msgid "Disable inbound IPv4 connections (firewalled)"
msgstr "ইনবাউন্ড IPv4 সংযোগ নিষ্ক্রিয় করুন (ফায়ারওয়ালযুক্ত)"

msgid "Enable UPnP to open firewall ports"
msgstr "ফায়ারওয়াল পোর্ট খুলতে UPnP সক্রিয় করুন"

msgid ""
"This mode enhances anonymity by preventing correlation between public IP "
"address changes and your router identity. Both your router identity and UDP "
"port will be changed."
msgstr ""
"এই মোড পাবলিক IP ঠিকানা পরিবর্তন এবং আপনার রাউটার পরিচয়ের মধ্যে সম্পর্ক "
"প্রতিরোধ করে anonymity বাড়ায়। আপনার রাউটার পরিচয় এবং UDP পোর্ট উভয়ই "
"পরিবর্তিত হবে।"

msgid "Laptop mode"
msgstr "ল্যাপটপ মোড"

msgid "This is an experimental feature"
msgstr "এটি একটি পরীক্ষামূলক বৈশিষ্ট্য"

msgid "Experimental"
msgstr "পরীক্ষামূলক"

msgid "IPv6 Configuration"
msgstr "IPv6 কনফিগারেশন"

msgid "Disable inbound (firewalled)"
msgstr "ইনবাউন্ড নিষ্ক্রিয় করুন (ফায়ারওয়ালযুক্ত)"

msgid "Disable IPv6"
msgstr "IPv6 নিষ্ক্রিয় করুন"

msgid "Enable IPv6"
msgstr "IPv6 সক্রিয় করুন"

msgid "Prefer IPv4 over IPv6"
msgstr "IPv6-এর উপর IPv4 পছন্দ করুন"

msgid "Prefer IPv6 over IPv4"
msgstr "IPv4-এর উপর IPv6 পছন্দ করুন"

msgid "Use IPv6 only (disable IPv4)"
msgstr "শুধুমাত্র IPv6 ব্যবহার করুন (IPv4 নিষ্ক্রিয় করুন)"

msgid "TCP Configuration"
msgstr "TCP কনফিগারেশন"

msgid "Use auto-detected IP address"
msgstr "স্বয়ং-শনাক্তকৃত IP ঠিকানা ব্যবহার করুন"

msgid "if we are not firewalled"
msgstr "যদি আমরা ফায়ারওয়ালযুক্ত না থাকি"

msgid "Always use auto-detected IP address (not firewalled)"
msgstr "সর্বদা স্বয়ং-শনাক্তকৃত IP ঠিকানা ব্যবহার করুন (ফায়ারওয়ালযুক্ত নয়)"

msgid "Disable inbound TCP connections (firewalled)"
msgstr "ইনবাউন্ড TCP সংযোগ নিষ্ক্রিয় করুন (ফায়ারওয়ালযুক্ত)"

msgid "Select only if behind a firewall that throttles or blocks outbound TCP"
msgstr ""
"শুধুমাত্র যদি এমন ফায়ারওয়ালের পিছনে থাকেন যা আউটবাউন্ড TCP সীমিত বা ব্লক "
"করে"

msgid "Completely disable TCP connections"
msgstr "সম্পূর্ণরূপে TCP সংযোগ নিষ্ক্রিয় করুন"

msgid "TCP port"
msgstr "TCP পোর্ট"

msgid "Use the same port configured for UDP"
msgstr "UDP-র জন্য কনফিগার করা একই পোর্ট ব্যবহার করুন"

msgid "currently"
msgstr "বর্তমানে"

msgid "Specify port"
msgstr "পোর্ট নির্দিষ্ট করুন"

msgid "UDP Configuration"
msgstr "UDP কনফিগারেশন"

msgid "UDP port"
msgstr "UDP পোর্ট"

msgid "Select only if behind a firewall that blocks outbound UDP"
msgstr "শুধুমাত্র যদি এমন ফায়ারওয়ালের পিছনে থাকেন যা আউটবাউন্ড UDP ব্লক করে"

msgid "Completely disable UDP connections"
msgstr "সম্পূর্ণরূপে UDP সংযোগ নিষ্ক্রিয় করুন"

msgid ""
"The router's external port allows communication with other routers. It is "
"recommended to configure your firewall to allow inbound and outbound traffic"
" on this port to optimize your router's performance on the network."
msgstr ""
"রাউটারের বাহ্যিক পোর্ট অন্যান্য রাউটারের সাথে যোগাযোগের অনুমতি দেয়। "
"নেটওয়ার্কে আপনার রাউটারের কর্মক্ষমতা অনুকূল করতে এই পোর্টে ইনবাউন্ড এবং "
"আউটবাউন্ড ট্রাফিক অনুমতি দেওয়ার জন্য আপনার ফায়ারওয়াল কনফিগার করার সুপারিশ"
" করা হয়।"

msgid ""
"Do not reveal your port numbers to anyone, as they can be used to discover "
"your IP address."
msgstr ""
"আপনার পোর্ট নম্বর কাউকে প্রকাশ করবেন না, কারণ সেগুলি আপনার IP ঠিকানা "
"আবিষ্কার করতে ব্যবহার করা যেতে পারে।"

msgid "config peers"
msgstr "পিয়ার কনফিগারেশন"

msgid "Peer Manager"
msgstr "পিয়ার ব্যবস্থাপক"

msgid "Manual Peer Controls"
msgstr "ম্যানুয়াল পিয়ার নিয়ন্ত্রণ"

msgid "Router Hash"
msgstr "রাউটার হ্যাশ"

msgid "Manually Ban / Unban a Peer"
msgstr "ম্যানুয়ালি একটি পিয়ার নিষিদ্ধ/অনিষিদ্ধ করুন"

msgid ""
"Banning will prevent the participation of this peer in tunnels you create."
msgstr "নিষেধাজ্ঞা আপনার তৈরি টানেলে এই পিয়ারের অংশগ্রহণ প্রতিরোধ করবে।"

msgid "A list of bans by IP address is presented below."
msgstr "IP ঠিকানা অনুযায়ী নিষেধাজ্ঞার একটি তালিকা নীচে উপস্থাপন করা হয়েছে।"

#, java-format
msgid "To view all active bans by router hash, see {0}Banned Peers{1}."
msgstr ""
"রাউটার হ্যাশ অনুযায়ী সমস্ত সক্রিয় নিষেধাজ্ঞা দেখতে, {0}নিষিদ্ধ পিয়ার{1} "
"দেখুন।"

#, java-format
msgid "A list of {0}session-only bans{1} by hash is also available."
msgstr ""
"হ্যাশ অনুযায়ী {0}শুধুমাত্র সেশন ভিত্তিক নিষেধাজ্ঞা{1}-এর একটি তালিকাও "
"উপলব্ধ।"

msgid "Adjust Profile Bonuses"
msgstr "প্রোফাইল বোনাস সামঞ্জস্য করুন"

msgid ""
"Bonuses may be positive or negative, and affect the peer's inclusion in Fast"
" and High Capacity tiers. Fast peers are used for client tunnels, and High "
"Capacity peers are used for some exploratory tunnels."
msgstr ""
"বোনাস ধনাত্মক বা ঋণাত্মক হতে পারে, এবং ফাস্ট এবং হাই ক্যাপাসিটি স্তরে "
"পিয়ারের অন্তর্ভুক্তি প্রভাবিত করে। ফাস্ট পিয়ার ক্লায়েন্ট টানেলের জন্য এবং"
" হাই ক্যাপাসিটি পিয়ার কিছু অনুসন্ধানমূলক টানেলের জন্য ব্যবহৃত হয়।"

msgid "Banned IP Addresses"
msgstr "নিষিদ্ধ IP ঠিকানা"

msgid "config plugins"
msgstr "প্লাগইন কনফিগারেশন"

msgid "Plugin Installation"
msgstr "প্লাগইন ইনস্টলেশন"

#, java-format
msgid "For available plugins, visit {0}."
msgstr "উপলব্ধ প্লাগইনের জন্য, {0} দেখুন।"

msgid "Enter xpi2p or su3 plugin URL"
msgstr "xpi2p বা su3 প্লাগইন URL লিখুন"

msgid "To install a plugin, enter the download URL:"
msgstr "প্লাগইন ইনস্টল করতে, ডাউনলোড URL লিখুন:"

msgid "Select xpi2p or su3 file"
msgstr "xpi2p বা su3 ফাইল নির্বাচন করুন"

msgid "Please supply a valid plugin file"
msgstr "অনুগ্রহ করে একটি বৈধ প্লাগইন ফাইল প্রদান করুন"

msgid "Plugin Manager"
msgstr "প্লাগইন ব্যবস্থাপক"

msgid "The plugins listed below are started by the webConsole client."
msgstr ""
"নীচে তালিকাভুক্ত প্লাগইনগুলি webConsole ক্লায়েন্ট দ্বারা শুরু করা হয়।"

msgid "config reseeding"
msgstr "পুনঃসীড কনফিগারেশন"

msgid ""
"Reseeding is the bootstrapping process used to find other routers when you "
"first install I2P, or when your router has too few router references "
"remaining."
msgstr ""
"পুনঃসীড হল বুটস্ট্র্যাপিং প্রক্রিয়া যা আপনি প্রথম I2P ইনস্টল করার সময় বা "
"আপনার রাউটারে খুব কম রাউটার রেফারেন্স অবশিষ্ট থাকলে অন্যান্য রাউটার খুঁজতে "
"ব্যবহৃত হয়।"

msgid ""
"To enable the configuration of reseed urls, activate the console's <a "
"href=/help/advancedsettings>Advanced mode</a>."
msgstr ""
"পুনঃসীড URL কনফিগারেশন সক্ষম করতে, কনসোলের <a "
"href=/help/advancedsettings>উন্নত মোড</a> সক্রিয় করুন।"

msgid "Reseeding Configuration"
msgstr "পুনঃসীড কনফিগারেশন"

msgid "Help with reseeding"
msgstr "পুনঃসীডে সহায়তা"

msgid "Reseeding Help"
msgstr "পুনঃসীড সহায়তা"

msgid "Reseed URLs"
msgstr "পুনঃসীড URL"

msgid "Reseed URL Selection"
msgstr "পুনঃসীড URL নির্বাচন"

msgid "Try SSL first then non-SSL"
msgstr "প্রথমে SSL তারপর নন-SSL ব্যবহার করে দেখুন"

msgid "Use SSL only"
msgstr "শুধুমাত্র SSL ব্যবহার করুন"

msgid "Use non-SSL only"
msgstr "শুধুমাত্র নন-SSL ব্যবহার করুন"

msgid "Use Proxy for HTTPS Reseed Hosts"
msgstr "HTTPS পুনঃসীড হোস্টের জন্য প্রক্সি ব্যবহার করুন"

msgid "Use Proxy to Reseed"
msgstr "পুনঃসীড করতে প্রক্সি ব্যবহার করুন"

msgid "HTTPS"
msgstr "HTTPS"

msgid "SOCKS 4/4a"
msgstr "SOCKS 4/4a"

msgid "SOCKS 5"
msgstr "SOCKS 5"

msgid ""
"This option will use I2P's HTTP outproxy to reseed, or the Orchid plugin if "
"configured. Note: this option will not work when you have 0 known peers."
msgstr ""
"এই বিকল্পটি পুনঃসীড করতে I2P-এর HTTP আউটপ্রক্সি ব্যবহার করবে, অথবা কনফিগার "
"করা থাকলে Orchid প্লাগইন ব্যবহার করবে। নোট: আপনার 0 টি পরিচিত পিয়ার থাকলে "
"এই বিকল্পটি কাজ করবে না।"

msgid "I2P Outproxy"
msgstr "I2P আউটপ্রক্সি"

msgid "Use HTTP Proxy for HTTP Reseed Hosts"
msgstr "HTTP পুনঃসীড হোস্টের জন্য HTTP প্রক্সি ব্যবহার করুন"

msgid "Proxy requires authorization"
msgstr "প্রক্সির অনুমোদন প্রয়োজন"

msgid "Manual Reseed"
msgstr "ম্যানুয়াল পুনঃসীড"

msgid ""
"The su3 format is preferred, as it will be verified as signed by a trusted "
"source."
msgstr ""
"su3 ফরম্যাট পছন্দনীয়, কারণ এটি একটি বিশ্বস্ত উৎস দ্বারা স্বাক্ষরিত হিসাবে "
"যাচাই করা হবে।"

msgid ""
"The zip format is unsigned; use a zip file only from a source that you "
"trust."
msgstr ""
"zip ফরম্যাট অস্বাক্ষরিত; শুধুমাত্র আপনার বিশ্বস্ত উৎস থেকে zip ফাইল ব্যবহার "
"করুন।"

msgid "Enter zip or su3 URL"
msgstr "zip বা su3 URL লিখুন"

msgid "Please supply a valid reseed URL"
msgstr "অনুগ্রহ করে একটি বৈধ পুনঃসীড URL প্রদান করুন"

msgid "Select zip or su3 file"
msgstr "zip বা su3 ফাইল নির্বাচন করুন"

msgid "Create Reseed File"
msgstr "পুনঃসীড ফাইল তৈরি করুন"

msgid ""
"Create a new reseed zip file you may share for others to reseed manually."
msgstr ""
"একটি নতুন পুনঃসীড zip ফাইল তৈরি করুন যা আপনি অন্যদের ম্যানুয়ালি পুনঃসীড "
"করতে শেয়ার করতে পারেন।"

msgid "This file will never contain your own router's identity or IP."
msgstr "এই ফাইলে কখনই আপনার নিজের রাউটারের পরিচয় বা IP থাকবে না।"

msgid "Create reseed file"
msgstr "পুনঃসীড ফাইল তৈরি করুন"

msgid "config service"
msgstr "সার্ভিস কনফিগারেশন"

msgid "Router Service"
msgstr "রাউটার সার্ভিস"

msgid "Shutdown the router"
msgstr "রাউটার বন্ধ করুন"

msgid ""
"Graceful mode allows your router to honor its participating tunnel "
"commitments before shutting down or restarting."
msgstr ""
"গ্রেসফুল মোড আপনার রাউটারকে বন্ধ বা পুনরায় চালু করার আগে তার অংশগ্রহণকারী "
"টানেল প্রতিশ্রুতি পূরণ করতে দেয়।"

msgid "Restart the router"
msgstr "রাউটার পুনরায় চালু করুন"

msgid ""
"A restart may be required to update the router, implement a configuration "
"change, or complete installation of a plugin."
msgstr ""
"রাউটার আপডেট করতে, কনফিগারেশন পরিবর্তন বাস্তবায়ন করতে, বা প্লাগইন ইনস্টলেশন"
" সম্পূর্ণ করতে পুনরায় চালুর প্রয়োজন হতে পারে।"

msgid "Launch console at startup"
msgstr "স্টার্টআপে কনসোল চালু করুন"

msgid "Help with configuring I2P to use a non-system default browser"
msgstr ""
"I2P-কে নন-সিস্টেম ডিফল্ট ব্রাউজার ব্যবহার করতে কনফিগার করার ক্ষেত্রে সহায়তা"

msgid "Launch I2P Router Console in web browser when I2P starts."
msgstr "I2P শুরু হলে ওয়েব ব্রাউজারে I2P রাউটার কনসোল চালু করুন।"

msgid "Debugging"
msgstr "ডিবাগিং"

#, java-format
msgid ""
"To assist in debugging I2P, it may be helpful to generate a thread dump "
"which will be written to the {0}wrapper log{1}."
msgstr ""
"I2P ডিবাগ করতে সহায়তা করার জন্য, একটি থ্রেড ডাম্প তৈরি করা সহায়ক হতে পারে "
"যা {0}wrapper log{1}-এ লেখা হবে।"

msgid ""
"If I2P appears to be using too much ram, you can force the router to run the"
" garbage collection routine to free up memory."
msgstr ""
"যদি I2P খুব বেশি RAM ব্যবহার করছে বলে মনে হয়, আপনি মেমরি মুক্ত করতে "
"রাউটারকে গার্বেজ কালেকশন রুটিন চালাতে বাধ্য করতে পারেন।"

msgid "System Tray Integration"
msgstr "সিস্টেম ট্রে ইন্টিগ্রেশন"

msgid ""
"Enable or disable the I2P system tray applet to enable basic service "
"control."
msgstr ""
"মৌলিক সার্ভিস নিয়ন্ত্রণ সক্ষম করতে I2P সিস্টেম ট্রে অ্যাপলেট সক্রিয় বা "
"নিষ্ক্রিয় করুন।"

msgid "Configure I2P system service"
msgstr "I2P সিস্টেম সার্ভিস কনফিগার করুন"

msgid ""
"Configure the status of the I2P service at system startup. If disabled, the "
"service can be launched manually."
msgstr ""
"সিস্টেম স্টার্টআপে I2P সার্ভিসের স্থিতি কনফিগার করুন। নিষ্ক্রিয় থাকলে, "
"সার্ভিসটি ম্যানুয়ালি চালু করা যেতে পারে।"

msgid "Install I2P system service"
msgstr "I2P সিস্টেম সার্ভিস ইনস্টল করুন"

msgid ""
"Install the I2P system service. This is the recommended way to run I2P."
msgstr "I2P সিস্টেম সার্ভিস ইনস্টল করুন। এটি I2P চালানোর প্রস্তাবিত উপায়।"

msgid "config sidebar"
msgstr "সাইডবার কনফিগারেশন"

msgid "Sidebar Options"
msgstr "সাইডবার বিকল্প"

msgid "Refresh interval"
msgstr "রিফ্রেশ অন্তর"

msgid "seconds"
msgstr "সেকেন্ড"

msgid "0 to disable"
msgstr "নিষ্ক্রিয় করতে 0"

msgid "Unified sidebar"
msgstr "ইউনিফাইড সাইডবার"

msgid "Use the same sidebar on all pages"
msgstr "সমস্ত পৃষ্ঠায় একই সাইডবার ব্যবহার করুন"

msgid "Sticky sidebar"
msgstr "স্টিকি সাইডবার"

msgid "Enable conditional fixed sidebar"
msgstr "শর্তসাপেক্ষ ফিক্সড সাইডবার সক্রিয় করুন"

msgid "Graph Options"
msgstr "গ্রাফ বিকল্প"

msgid "Legacy renderer"
msgstr "লেগাসি রেন্ডারার"

msgid "Use RRD4J renderer"
msgstr "RRD4J রেন্ডারার ব্যবহার করুন"

msgid "minutes (2–30)"
msgstr "মিনিট (২–৩০)"

msgid "Split display"
msgstr "বিভক্ত প্রদর্শন"

msgid "Separate Inbound and Outbound"
msgstr "ইনবাউন্ড ও আউটবাউন্ড পৃথক করুন"

msgid "Graph direction"
msgstr "গ্রাফ দিক"

msgid "Left-to-right"
msgstr "বাম থেকে ডান"

msgid "Refresh Interval"
msgstr "রিফ্রেশ বিরতি"

msgid "Update graph every second"
msgstr "প্রতি সেকেন্ডে গ্রাফ আপডেট করুন"

msgid "config stats"
msgstr "স্ট্যাট কনফিগারেশন"

msgid "Stats Collection &amp; Graphing"
msgstr "স্ট্যাট সংগ্রহ এবং গ্রাফিং"

msgid "Configure I2P Stat Collection"
msgstr "I2P স্ট্যাট সংগ্রহ কনফিগার করুন"

msgid ""
"A limited selection of stats is enabled by default, required for monitoring "
"router performance. Only stats that have an optional graph are listed here; "
"for a full list of enabled stats, view the <a href=\"/stats\">stats "
"page</a>."
msgstr ""
"সীমিত পরিসংখ্যান ডিফল্টরূপে সক্রিয়, রাউটার স্বাস্থ্য পর্যবেক্ষণ এবং সমস্যা "
"সমাধানের জন্য প্রয়োজনীয়। false-তে সেট করা হলে, সমস্ত পরিসংখ্যান নিষ্ক্রিয়"

msgid ""
msgstr "Language: bn\nMIME-Version: 1.0\nContent-Type: text/plain; charset=UTF-8\nContent-Transfer-Encoding: 8bit\nPlural-Forms: nplurals=2; plural=(n != 1);\n"
msgid "I2P+ installation complete!"
msgstr "I2P+ ইনস্টলেশন সম্পূর্ণ!"

msgid "Welcome to I2P+!"
msgstr "I2P+-এ স্বাগতম!"

#, java-format
msgid "Please {0}have patience{1} as I2P+ boots up and finds peers."
msgstr "I2P+ বুট আপ হয়ে পিয়ার খুঁজে না পাওয়া পর্যন্ত অনুগ্রহ করে {0}ধৈর্য ধরুন{1}।"

#, java-format
msgid "While you are waiting, please {0}adjust your bandwidth settings{1} on the {2}configuration page{3}."
msgstr "আপনি অপেক্ষা করছেন, দয়া করে {2}কনফিগারেশন পৃষ্ঠায়{3} আপনার {0}ব্যান্ডউইথ সেটিংস{1} সামঞ্জস্য করুন।"

#, java-format
msgid "You can also run the bandwidth test via the {0}Setup Wizard{1} to help with determining your bandwidth, and a guide for new users and additional documentation including an FAQ is available in the {2}help section{1}."
msgstr "আপনি {0}সেটআপ উইজার্ড{1}-এর মাধ্যমেও ব্যান্ডউইথ পরীক্ষা চালাতে পারেন, এবং নতুন ব্যবহারকারীদের জন্য একটি গাইড ও FAQ সহ অতিরিক্ত ডকুমেন্টেশন {2}সহায়তা বিভাগে{1} উপলব্ধ।"

#, java-format
msgid "You may also wish to enable I2P+ updates on {0}the update configuration page{1}."
msgstr "আপনি {0}আপডেট কনফিগারেশন পৃষ্ঠায়{1} I2P+ আপডেট সক্রিয় করতে চাইতে পারেন।"

msgid "Also you can setup your browser to use the I2P proxy to reach eepsites."
msgstr "আপনি eepসাইটে পৌঁছানোর জন্য আপনার ব্রাউজারে I2P প্রক্সি সেটআপ করতে পারেন।"

msgid "Just enter 127.0.0.1 (or localhost) port 4444 as a http proxy into your browser settings."
msgstr "শুধু আপনার ব্রাউজার সেটিংসে http প্রক্সি হিসাবে 127.0.0.1 (বা লোকালহোস্ট) পোর্ট 4444 লিখুন।"

msgid "Do not use SOCKS for this."
msgstr "এর জন্য SOCKS ব্যবহার করবেন না।"

#, java-format
msgid "More information can be found on the {0}I2P browser proxy setup page{1}."
msgstr "{0}I2P ব্রাউজার প্রক্সি সেটআপ পৃষ্ঠায়{1} আরও তথ্য পাওয়া যাবে।"

#, java-format
msgid "Point your IRC client to {0}localhost:6668{1} and say hi to us on {2}#saltR{3}."
msgstr "আপনার IRC ক্লায়েন্ট {0}localhost:6668{1}-এ পয়েন্ট করুন এবং {2}#saltR{3}-এ আমাদের জানান।"

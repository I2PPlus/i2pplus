msgstr "হ্রাসকৃত টানেল নিষ্ক্রিয় সময়"

msgid "Reduced count"
msgstr "হ্রাসকৃত সংখ্যা"

msgid "Reduced tunnel count"
msgstr "হ্রাসকৃত টানেল সংখ্যা"

msgid "Close tunnels when idle"
msgstr "নিষ্ক্রিয় অবস্থায় টানেল বন্ধ করুন"

msgid "To conserve resources, close tunnels when not in use"
msgstr "সম্পদ সংরক্ষণ করতে, ব্যবহার না হলে টানেল বন্ধ করুন"

msgid "Close client tunnels after specified idle period"
msgstr "নির্দিষ্ট নিষ্ক্রিয় সময়ের পরে ক্লায়েন্ট টানেল বন্ধ করুন"

msgid "Close Tunnel Idle Time"
msgstr "টানেল বন্ধের নিষ্ক্রিয় সময়"

msgid "New Keys on Reopen"
msgstr "পুনরায় খোলার সময় নতুন কী"

msgid "Change tunnel identity (destination) when tunnels reopen"
msgstr "টানেল পুনরায় খোলার সময় টানেল পরিচয় (গন্তব্য) পরিবর্তন করুন"

msgid "Enable"
msgstr "সক্রিয়"

msgid "Retain tunnel identity (destination) when tunnels reopen"
msgstr "টানেল পুনরায় খোলার সময় টানেল পরিচয় (গন্তব্য) ধরে রাখুন"

msgid "Disable"
msgstr "নিষ্ক্রিয়"

msgid "Persistent private key"
msgstr "স্থায়ী ব্যক্তিগত কী"

msgid "Private key file"
msgstr "ব্যক্তিগত কী ফাইল"

msgid "Enabling this feature will ensure your tunnel identity (destination) remains static, for services offering features based on destination e.g. IRC user authentication"
msgstr "এই বৈশিষ্ট্যটি সক্রিয় করলে নিশ্চিত হবে যে আপনার টানেল পরিচয় (গন্তব্য) স্থির থাকে, গন্তব্যের উপর ভিত্তি করে বৈশিষ্ট্য প্রদানকারী পরিষেবাগুলির জন্য যেমন IRC ব্যবহারকারী প্রমাণীকরণ"

msgid "Generate key to enable persistent client tunnel identity"

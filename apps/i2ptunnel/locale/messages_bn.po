msgid "Tunnel Options"
msgstr "টানেল বিকল্প"

msgid "Length"
msgstr "দৈর্ঘ্য"

msgid "Count"
msgstr "গণনা"

msgid "Length of each Tunnel"
msgstr "প্রতিটি টানেলের দৈর্ঘ্য"


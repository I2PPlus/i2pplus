msgstr "སྒྲོམ་ལམ་བཟོ་རྒྱུ་མེད་པའི་ཚེ་བརྒྱབ་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:925
msgid "To conserve resources, close tunnels when not in use"
msgstr "ནུས་ཤུགས་བཟོ་རྒྱུ་བྱོས་པ་དང་སྒྲོམ་ལམ་བཟོ་རྒྱུ་མེད་པའི་ཚེ་བརྒྱབ་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:929
msgid "Close client tunnels after specified idle period"
msgstr "སྒྲོམ་ལམ་གཞིར་བཟོ་བའི་ཉིན་རེའི་བར་ཐག་བཟོ་རྒྱུ་བྱོས་པ་དང་སྒྲོམ་ལམ་བརྒྱབ་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:933
msgid "Close Tunnel Idle Time"
msgstr "སྒྲོམ་ལམ་གཞིར་བཟོ་བའི་ཉིན་རེའི་བར་ཐག་།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:937
msgid "New Keys on Reopen"
msgstr "བརྒྱབ་པ་ནས་ཡང་བཟོ་རྒྱུའི་གདམ་ག་གསར་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:939
msgid "Change tunnel identity (destination) when tunnels reopen"
msgstr "སྒྲོམ་ལམ་ཡང་བཟོ་རྒྱུའི་ཚེ་སྒྲོམ་ལམ་གི་མིང་(བྱེད་འདྲི) བཅོས་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:943
msgid "Enable"
msgstr "བཟོ་རྒྱུ་བྱོས།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:945
msgid "Retain tunnel identity (destination) when tunnels reopen"
msgstr "སྒྲོམ་ལམ་ཡང་བཟོ་རྒྱུའི་ཚེ་སྒྲོམ་ལམ་གི་མིང་(བྱེད་འདྲི) བཟོ་མི་བྱེད་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:949
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:2148
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:2157
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:2369
msgid "Disable"
msgstr "བཟོ་རྒྱུ་མི་བྱོས།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:953
msgid "Persistent private key"
msgstr "རྒྱུན་གོའི་གདམ་ག་གཞིར་བཟོ་བ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:955
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:1357
msgid "Private key file"
msgstr "གདམ་ག་གཞིར་བཟོ་བའི་ཡིག་ཆ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:957
msgid ""
"Enabling this feature will ensure your tunnel identity (destination) remains "
"static, for services offering features based on destination e.g. IRC user "
"authentication"
msgstr ""
"འདིའི་ནུས་པ་བཟོ་རྒྱུ་ཁྱོད་ཀྱི་སྒྲོམ་ལམ་གི་མིང་(བྱེད་འདྲི) རྒྱུན་དུ་བཟོ་རྒྱུ་བྱོས་པ་དང་བྱེད་འདྲི་གཞིར་བཟོ་བའི་ཞབས་"
"ཞུ་བཟོ་རྒྱུར་བཅོས་པ། དཔེར་ན། IRC སྤྱོད་མཁན་གཞིར་བཟོ་བ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:961
msgid "Generate key to enable persistent client tunnel identity"
msgstr "རྒྱུན་གོའི་སྤྱོད་མཁན་སྒྲོམ་ལམ་གི་མིང་བཟོ་རྒྱུར་གདམ་ག་བཟོ་བ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:963
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:1367
msgid "Path to Private Key File"
msgstr "གདམ་ག་གཞིར་བཟོ་བའི་ཡིག་ཆའི་ལམ་ཐོབ་ཐང་།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:971
msgid "HTTP Filtering"
msgstr "HTTP གཞིར་བཟོ་བའི་བརྟག་བཟོ་བ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:973
msgid ""
"When enabled, the user agent of your web browser or http client will not be "
"spoofed, potentially reducing your anonymity"
msgstr ""
"འདིའི་ནུས་པ་བཟོ་རྒྱུ་ཁྱོད་ཀྱི་རྟེན་གློག་བོད་མིང་དང་HTTP སྤྱོད་མཁན་གི་མིང་བཟོ་རྒྱུ་མི་བྱེད་པ་དང་ཁྱོད་ཀྱི་མིང་"
"གཞིར་བཟོ་བའི་ནུས་པ་ཉུང་བར་བཅོས་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:977
msgid "Do not spoof User-Agent header"
msgstr "སྤྱོད་མཁན་མིང་གཞིར་བཟོ་བའི་མཚོན་རིས་བཟོ་མི་བྱེད་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:979
msgid ""
"When enabled, the referer (originating page) of your web requests will not "
"be filtered, potentially reducing your anonymity"
msgstr ""
"འདིའི་ནུས་པ་བཟོ་རྒྱུ་ཁྱོད་ཀྱི་རྟེན་གློག་བོད་མིང་ནས་འགྲོ་བའི་ཐོབ་ཐང་བཟོ་རྒྱུ་མི་བྱེད་པ་དང་ཁྱོད་ཀྱི་མིང་གཞིར་བཟོ་"
"བའི་ནུས་པ་ཉུང་བར་བཅོས་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:983
msgid "Do not block Referer header"
msgstr "ཐོབ་ཐང་གཞིར་བཟོ་བའི་མཚོན་རིས་བཟོ་མི་བྱེད་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:985
msgid ""
"When enabled, the accept headers (mime types support) broadcast by your web "
"browser will not be filtered, potentially reducing your anonymity"
msgstr ""
"འདིའི་ནུས་པ་བཟོ་རྒྱུ་ཁྱོད་ཀྱི་རྟེན་གློག་བོད་མིང་གི་བཙན་བཟོ་བའི་མཚོན་རིས་(mime རིགས་བཟོ་བ་) བཟོ་རྒྱུ་མི་བྱེད་"
"པ་དང་ཁྱོད་ཀྱི་མིང་གཞིར་བཟོ་བའི་ནུས་པ་ཉུང་བར་བཅོས་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:989
msgid "Do not block Accept headers"
msgstr "བཙན་བཟོ་བའི་མཚོན་རིས་བཟོ་མི་བྱེད་པ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:991
msgid "Allow SSL to I2P addresses when enabled"
msgstr "འདིའི་ནུས་པ་བཟོ་རྒྱུ་I2P གི་ཐོབ་ཐང་ནས་SSL བཟོ་རྒྱུ་བྱོས།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:995
msgid "Allow SSL to I2P addresses"
msgstr "I2P གི་ཐོབ་ཐང་ནས་SSL བཟོ་རྒྱུ་བྱོས།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:1001
msgid "Local Authorization"
msgstr "ནང་གི་གཞིར་བཟོ་བ།"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:1003
msgid "Local Credentials"
msgstr "ནང་གི་བཙན་བཟོ་བའི་གདམ་ག་"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:1005
msgid ""
"Enable to require a username and password to access this local service (for "

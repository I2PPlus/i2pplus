msgstr ""
"སྒྲོམ་ལམ་གཞིར་བཟོ་བའི་གྲངས་ཀ་ཉུང་བ་ནུས་ཤུགས་བཟོ་རྒྱུ་བྱོས་པ་དང་སྒྲོམ་ལམ་འགོ་ཚུགས་བཞིན་པ། (རྒྱུན་དུ་བཟོ་"
"རྒྱུའི་ནུས་པ་བྱོས་པའི་རྒྱུ།)"

#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:909
#: ../jsp/WEB-INF/classes/net/i2p/i2ptunnel/jsp/edit_jsp.java:2047
msgid "Reduce tunnel quantity when idle"
msgstr "སྒྲོམ་ལམ་གཞིར་བཟོ་བའི་གྲངས་ཀ་ཉུང་བ་ནུས་ཤུགས་བཟོ་རྒྱུ་བྱོས་པ།"


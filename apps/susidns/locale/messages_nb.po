msgstr[1] "Hoppet over {0} duplikate oppføringer fra fil"

msgid "Import from file failed"
msgstr "Importering fra fil feilet"

msgid "Subscriptions saved."
msgstr "Abonnementer lagret."

msgid "Update"
msgstr "Oppdater"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Prøver å oppdatere adressoboken fra abonnementkilder..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Kan ikke oppdatere abonnementer: HTTP-proxyen kjører ikke!"

msgid "Subscriptions reloaded."
msgstr "Abonnementer lastet opp igjen."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Hvis DNS er konfigurert til å publisere din Ruter adressebok, vil inntrykkene dukke opp i din Publiserte adressebok og lagres til en hosts.txt-fil for deling."

msgid "Published Addressbook"
msgstr "Publisert Adressebok"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "For å konfigurere DNS til å sende din Ruter adressebok til din Publiserte adressebok, sett 'should_publish=true' på konfigurasjons siden."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Alle vertene som følger av abonnementer vil dukke opp i denne adresseboken, i tillegg til alle du legger til manuelt her eller i din Hoved adressebok."

msgid "Router Addressbook"
msgstr "Ruter Adressebok"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Vertene du legger til manuelt her vil aldri bli publisert. Du kan også legge til alias til vertene i andre adressebøker her."

msgid "Private Addressbook"
msgstr "Privat Adressebok"

msgid "Local Records"
msgstr "Lokale poster"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "I2P-applikasjoner (inkludert HTTP-proxyen) bruker vertene i dine lokale adressebøker til å løse opp .i2p vertnavn."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "Ekstra abonnementer kan finnes i FAQ-seksjonen på Routerns hjelpeside."

msgid "Subscriptions"
msgstr "Abonnementer"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Vertene som kommer fra dine abonnementer legges til i din Ruter adressebok, og synkroniseres automatisk (som standard hvert 12. time)."

msgid "Configure Subscriptions"
msgstr "Konfigurer Abonnementer"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Hvis du legger til vertene manuelt her, vil de bli inkludert i din Publiserte adressebok (hvis konfigurert)."

msgid "Master Addressbook"
msgstr "Hoved Adressebok"

msgid "Searchable by"
msgstr "Søkbar etter"

msgid "I2P applications"
msgstr "I2P applikasjoner"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "Hoved, Ruter og Privat adressebøker tjenestegjør kollektivt som DNS-autoriteten for I2P-applikasjoner."

msgid "Optional,"
msgstr "Valgfritt,"

msgid "for websites"
msgstr "for nettsider"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Hvis du konfigurerer DNS til å publisere din Ruter adressebok, vil den eksportere en hosts.txt-fil som inneholder alle vertene (som standard til roten av din eepside)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "Adresser som legges til manuelt i din Hoved adressebok vil bli slått sammen med din Ruter adressebok."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Vertene du mottar fra dine abonnementer vil bli slått sammen med din Ruter adressebok."

msgstr "Seaded salvestatud."

msgid "Configuration reloaded."
msgstr "Seaded laaditi uuesti."

msgid "New domain"
msgstr "Uus domeen"

msgid "Subscription log reloaded."
msgstr "Tellimuse logi laaditi uuesti."


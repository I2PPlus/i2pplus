msgid_plural "{0} destinations blacklisted."
msgstr[0] "1 sihtkoht musta nimekirja lisatud."
msgstr[1] "{0} sihtkohta musta nimekirja lisatud."

msgid "No valid entries selected to blacklist."
msgstr "Musta nimekirja lisamiseks pole valitud ühtki kehtivat kirjet."

msgid "Save Notes"
msgstr "Salvesta märkused"

msgid "You must enter a file"
msgstr "Peate sisestama faili"

msgid "No entries found in file"
msgstr "Failis kirju ei leitud"

#, java-format
msgid "Imported from file {0}"
msgstr "Imporditud failist {0}"

#, java-format
msgid "Loaded {0} entry from file"
msgid_plural "Loaded {0} entries from file"
msgstr[0] "Laaditi failist {0} kirje"
msgstr[1] "Laaditi failist {0} kirjet"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "Vahele jäeti failist {0} korduv kirje"
msgstr[1] "Vahele jäeti failist {0} korduvat kirjet"

msgid "Import from file failed"
msgstr "Failist impord ebaõnnestus"

msgid "Subscriptions saved."
msgstr "Tellimused salvestatud."

msgid "Update"
msgstr "Uuenda"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Püüan uuendada aadressiraamat tellimuste allikatest..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Tellimusi ei saa uuendada: HTTP vahendusserver ei tööta!"

msgid "Subscriptions reloaded."
msgstr "Tellimused laaditi uuesti."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Kui DNS on seadistatud rooteri aadressiraamatu avaldamiseks, siis sisendid ilmuvad sinu Avaldatud aadressiraamatus ning salvestatakse hosts.txt faili jagamiseks."

msgid "Published Addressbook"
msgstr "Avaldatud Aadressiraamat"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "Et seadistada DNS rooteri aadressiraamatu edastamiseks sinu Avaldatud aadressiraamatusse, määra 'should_publish=true' seadistuslehel."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Kõik tellimuste põhjal leitud hostid ilmuvad selle aadressiraamatus, lisaks kõigile, mida lisad siia käsitsi või oma Põhi aadressiraamatusse."

msgid "Router Addressbook"
msgstr "Rooteri Aadressiraamat"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Hostsid, mida lisad siia käsitsi, ei avaldata kunagi. Siia saad lisada ka aliasid teiste aadressiraamatute hostidele."

msgid "Private Addressbook"
msgstr "Privaatne Aadressiraamat"

msgid "Local Records"
msgstr "Kohalikud Andmed"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "I2P rakendused ( sealhulgas HTTP proxy) kasutavad sinu kohalike aadressiraamatute hoste .i2p hostinimed lahendamiseks."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "Lisatellimused leidub Rooteri abi lehe FAQ-sektoris."

msgid "Subscriptions"
msgstr "Tellimused"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Tellimuste allikast pärit hostid lisatakse sinu Rooteri aadressiraamatusse ning neid sünkroniseeritakse automaatselt (vaikeväärtusel iga 12 tundi)."

msgid "Configure Subscriptions"
msgstr "Seadista Tellimused"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Kui lisad hostid siia käsitsi, siis need lisatakse sinu Avaldatud aadressiraamatusse (kui see on seadistatud)."

msgid "Master Addressbook"
msgstr "Põhi Aadressiraamat"

msgid "Searchable by"
msgstr "Otsitav"

msgid "I2P applications"
msgstr "I2P rakendused"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "Põhi-, Rooter- ja Privaatne aadressiraamatud koos moodustavad DNS autoriteedi I2P rakenduste jaoks."

msgid "Optional,"
msgstr "Valikuline,"

msgid "for websites"
msgstr "veebisaitide jaoks"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Kui seadistad DNS rooteri aadressiraamatu avaldamiseks, siis see eksporteeri hosts.txt faili kõigi hostidega (vaikeväärtusel sinu eepsaidi juurkausta)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "Käsitselt põhi aadressiraamatusse lisatud aadressid ühendatakse sinu Rooteri aadressiraamatusse."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Tellimuste kaudu saadud hostid ühendatakse sinu Rooteri aadressiraamatusse."

msgid_plural "{0} destinations deleted."
msgstr[0] "1 προορισμός διαγράφηκε."
msgstr[1] "{0} Οι προορισμοί διαγράφηκαν."

msgid "No valid entries selected to delete."
msgstr "Δεν επιλέχθηκαν έγκυρες καταχωρήσεις προς διαγραφή."

msgid "Add Alternate"
msgstr "Προσθήκη εναλλακτικού"

msgid "Address book saved."
msgstr "Το βιβλίο διευθύνσεων αποθηκεύτηκε."

msgid "ERROR: Could not write addressbook file."
msgstr "ΣΦΑΛΜΑ: Δεν μπόρεσε να εγγραφεί το αρχείο βιβλίου διευθύνσεων."

msgid "Invalid form submission, probably because you used the \"back\" or \"reload\" button on your browser. Please resubmit."
msgstr "Άκυρη αποστολή φόρμας, πιθανότατα γιατί χρησιμοποιήσατε το πλήκτρο \"πίσω\" ή \"επαναφόρτωση\" στον φυλλομετρητή σας. Παρακαλώ στείλατε πάλι."

msgid "If the problem persists, verify that you have cookies enabled in your browser."
msgstr "Αν το πρόβλημα επιμένει, βεβαιωθείτε ότι ο περιηγητής ιστού σας αποδέχεται τα cookies."

msgid "Save"
msgstr "Αποθήκευση"

msgid "Blacklist saved."
msgstr "Η μαύρη λίστα αποθηκεύτηκε."

msgid "Reload"
msgstr "Επαναφόρτωση"

msgid "Blacklist reloaded from file."
msgstr "Η μαύρη λίστα επαναφορτώθηκε από αρχείο."

msgid "Configuration saved."
msgstr "Παράμετροι αποθηκεύθηκαν."

msgid "Configuration reloaded."
msgstr "Παράμετροι επαναφορτώθηκαν."

msgid "New domain"
msgstr "Νέο τομέας"

msgid "Subscription log reloaded."
msgstr "Το αρχείο καταγραφής συνδρομής φορτώθηκε ξανά."

#, java-format
msgid "{0} address book in {1} database"
msgstr "{0} βιβλίο διευθύνσεων στη βάση δεδομένων {1}"

#, java-format
msgid "Host name {0} is not in the address book."
msgstr "Το όνομα κεντρικού υπολογιστή {0} δεν υπάρχει στο βιβλίο διευθύνσεων."

#, java-format
msgid "Failed to add Destination for {0} to naming service {1}"
msgstr "Απέτυχε η προσθήκη Προορισμού για το {0} στην υπηρεσία ονομασίας {1}"

#, java-format
msgid "Failed to delete Destination for {0} from naming service {1}"
msgstr "Αποτυχία διαγραφής προορισμού για {0} από την υπηρεσία ονοματοδοσίας {1}"

msgid "Blacklist Selected"
msgstr "Μαύρη Λίστα Επιλεγμένων"

#, java-format
msgid "1 destination blacklisted."
msgid_plural "{0} destinations blacklisted."
msgstr[0] "1 προορισμός στη μαύρη λίστα."
msgstr[1] "{0} προορισμοί στη μαύρη λίστα."

msgid "No valid entries selected to blacklist."
msgstr "Δεν επιλέχθηκαν έγκυρες καταχωρήσεις για μαύρη λίστα."

msgid "Save Notes"
msgstr "Αποθήκευση σημειώσεων"

msgid "You must enter a file"
msgstr "Πρέπει να εισάγετε αρχείο"

msgid "No entries found in file"
msgstr "Δεν βρέθηκαν καταχωρήσεις στο αρχείο"

#, java-format
msgid "Imported from file {0}"
msgstr "Εισαγωγή από το αρχείο {0}"

#, java-format
msgid "Loaded {0} entry from file"
msgid_plural "Loaded {0} entries from file"
msgstr[0] "Φορτωμένο {0} καταχώρηση από το αρχείο"
msgstr[1] "Φορτωμένες {0} καταχωρήσεις από το αρχείο"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "Παραλείποντας {0} διπλή καταχώρηση από το αρχείο"
msgstr[1] "Παραλείπονται {0} διπλές καταχωρήσεις από το αρχείο"

msgid "Import from file failed"
msgstr "Η εισαγωγή από το αρχείο απέτυχε"

msgid "Subscriptions saved."
msgstr "Συνδρομές αποθηκεύθηκαν."

msgid "Update"
msgstr "Ενημέρωση"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Προσπάθεια ενημέρωσης του βιβλίου διευθύνσεων από πηγές συνδρομής..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Δεν είναι δυνατή η ενημέρωση των συνδρομών: Ο διακομιστής μεσολάβησης HTTP δεν εκτελείται!"

msgid "Subscriptions reloaded."
msgstr "Συνδρομές επαναφορτώθηκαν."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Εάν το DNS έχει ρυθμιστεί να δημοσιεύει το βιβλίο διευθύνσεων του δρομολογητή σας, οι εγγραφές θα εμφανιστούν στο Δημοσιευμένο βιβλίο διευθύνσεων και θα αποθηκευτούν σε ένα αρχείο hosts.txt για κοινή χρήση."

msgid "Published Addressbook"
msgstr "Δημοσιευμένο Βιβλίο Διευθύνσεων"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "Για να διαμορφώσετε το DNS ώστε να ωθεί το βιβλίο διευθύνσεων του δρομολογητή σας στο Δημοσιευμένο βιβλίο διευθύνσεων, ορίστε το 'should_publish=true' στη σελίδα διαμόρφωσης."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Όλοι οι κεντρικοί υπολογιστές που προέρχονται από συνδρομές θα εμφανίζονται σε αυτό το βιβλίο διευθύνσεων, εκτός από οποιονδήποτε προσθέτετε χειροκίνητα εδώ ή στο Βιβλίο διευθύνσεων Master."

msgid "Router Addressbook"
msgstr "Βιβλίο διευθύνσεων δρομολογητή"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Οι κεντρικοί υπολογιστές που προσθέτετε χειροκίνητα εδώ δεν θα δημοσιευτούν ποτέ."

msgid "Private Addressbook"
msgstr "Ιδιωτικό βιβλίο διευθύνσεων"

msgid "Local Records"
msgstr "Τοπικά Αρχεία"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "Οι εφαρμογές του I2P (συμπεριλαμβανομένου του HTTP proxy) χρησιμοποιούν τους κόμβους στα τοπικά βιβλία διευθύνσεών σας για να επιλύουν τα ονόματα κεντρικών κόμβων .i2p."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "Μπορείτε να βρείτε πρόσθετες συνδρομές στην ενότητα Συχνές ερωτήσεις της σελίδας βοήθειας του δρομολογητή."

msgid "Subscriptions"
msgstr "Συνδρομές"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Οι κεντρικοί υπολογιστές που προέρχονται από τις συνδρομές σας προστίθενται στο βιβλίο διευθύνσεων του δρομολογητή σας και συγχρονίζονται αυτόματα (από προεπιλογή κάθε 12 ώρες)."

msgid "Configure Subscriptions"
msgstr "Διαμόρφωση συνδρομών"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Εάν προσθέσετε με μη αυτόματο τρόπο κεντρικούς υπολογιστές εδώ, θα συμπεριληφθούν το Δημοσιευμένο βιβλίο διευθύνσεών σας (αν έχουν ρυθμιστεί)."

msgid "Master Addressbook"
msgstr "Κύριο βιβλίο διευθύνσεων"

msgid "Searchable by"
msgstr "Δυνατότητα αναζήτησης κατά"

msgid "I2P applications"
msgstr "Εφαρμογές I2P"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "Τα βιβλία διευθύνσεων Master, Router και Private λειτουργούν συλλογικά ως αρχή DNS για εφαρμογές I2P."

msgid "Optional,"
msgstr "Προαιρετικά,"

msgid "for websites"
msgstr "για ιστότοπους"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Εάν διαμορφώσετε το DNS ώστε να δημοσιεύει το βιβλίο διευθύνσεων του δρομολογητή σας, θα εξαγάγει ένα αρχείο hosts.txt που περιέχει όλους τους κεντρικούς υπολογιστές (από προεπιλογή στη ρίζα του eepsite σας)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "Οι διευθύνσεις που προστέθηκαν χειροκίνητα στο Βιβλίο διευθύνσεων Master θα συγχωνευθούν με το βιβλίο διευθύνσεων του δρομολογητή."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Οι κεντρικοί υπολογιστές που λαμβάνετε από τις συνδρομές σας θα συγχωνευθούν με το βιβλίο διευθύνσεων του δρομολογητή σας."

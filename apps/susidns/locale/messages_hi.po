msgid "Destination added for {0}."
msgstr "{0} के लिए गंतव्य जोड़ा गया है।"

#, java-format
msgid "Destination changed for {0}."
msgstr "{0} के लिए गंतव्य बदल दिया गया है।"

msgid "Warning - host name does not end with \".i2p\""
msgstr "चेतावनी - होस्ट नाम \".i2p\" से समाप्त नहीं होता है"

msgid "Invalid Base 32 host name."
msgstr "अमान्य बेस 32 होस्ट नाम।"

msgid "Invalid Base 64 destination."
msgstr "अमान्य बेस 64 गंतव्य।"

#, java-format
msgid "Invalid host name \"{0}\"."
msgstr "अमान्य होस्ट नाम \"{0}\"।"

msgid "Please enter a host name and destination"
msgstr "कृपया एक होस्ट नाम और गंतव्य दर्ज करें"

msgid "Delete Entry"
msgstr "प्रविष्टि हटाएं"

msgid "Delete Selected"
msgstr "चुनी गई हटाएं"

#, java-format
msgid "Destination {0} deleted."
msgstr "गंतव्य {0} हटा दिया गया।"

#, java-format
msgid "1 destination deleted."
msgid_plural "{0} destinations deleted."
msgstr[0] "{0} गंतव्य हटा दिया गया।"
msgstr[1] "{0} गंतव्य हटे गए।"

msgid "No valid entries selected to delete."
msgstr "हटाने के लिए कोई वैध प्रविष्टियाँ चुनी नहीं गईं।"

msgid "Add Alternate"
msgstr "विकल्प जोड़ें"

msgid "Address book saved."
msgstr "पत्रिका सहेजा गया।"

msgid "ERROR: Could not write addressbook file."
msgstr "त्रुटि: पत्रिका फ़ाइल लिखने में असमर्थ।"

msgid "Invalid form submission, probably because you used the \"back\" or \"reload\" button on your browser. Please resubmit."
msgstr "अमान्य फॉर्म प्रस्तुति, शायद क्योंकि आपने अपने ब्राउज़र में \"वापस\" या \"रीलोड\" बटन का उपयोग किया। कृपया फिर से प्रस्तुत करें।"

msgid "If the problem persists, verify that you have cookies enabled in your browser."
msgstr "अगर समस्या जारी रहती है, तो सुनिश्चित करें कि आपके ब्राउज़र में कुकीज़ सक्षम हैं।"

msgid "Save"
msgstr "सहेजें"

msgid "Blacklist saved."
msgstr "ब्लैकलिस्ट सहेजा गया।"

msgid "Reload"
msgstr "पुनः लोड करें"

msgid "Blacklist reloaded from file."
msgstr "ब्लैकलिस्ट फ़ाइल से पुनः लोड किया गया।"

msgid "Configuration saved."
msgstr "निर्माण सहेजा गया।"

msgid "Configuration reloaded."
msgstr "निर्माण पुनः लोड किया गया।"

msgid "New domain"
msgstr "नया डोमेन"

msgid "Subscription log reloaded."
msgstr "सब्सक्रिप्शन लॉग पुनः लोड किया गया।"

#, java-format
msgid "{0} address book in {1} database"
msgstr "{0} पत्रिका {1} डेटाबेस में"

#, java-format
msgid "Host name {0} is not in the address book."
msgstr "होस्ट नाम {0} पत्रिका में नहीं है।"

#, java-format
msgid "Failed to add Destination for {0} to naming service {1}"
msgstr "{0} के लिए गंतव्य को नामिंग सेवा {1} में जोड़ने में विफलता"

#, java-format
msgid "Failed to delete Destination for {0} from naming service {1}"
msgstr "{0} के लिए गंतव्य को नामिंग सेवा {1} से हटाने में विफलता"

msgid "Blacklist Selected"
msgstr "ब्लैकलिस्ट चयनित"

#, java-format
msgid "1 destination blacklisted."
msgid_plural "{0} destinations blacklisted."
msgstr[0] "{0} गंतव्य ब्लैकलिस्ट में डाला गया।"
msgstr[1] "{0} गंतव्य ब्लैकलिस्ट में डाले गए।"

msgid "No valid entries selected to blacklist."
msgstr "ब्लैकलिस्ट में डालने के लिए कोई वैध प्रविष्टियाँ चुनी नहीं गईं।"

msgid "Save Notes"
msgstr "नोट्स सहेजें"

msgid "You must enter a file"
msgstr "आपको एक फ़ाइल दर्ज करना होगा"

msgid "No entries found in file"
msgstr "फ़ाइल में कोई प्रविष्टि नहीं मिली"

#, java-format
msgid "Imported from file {0}"
msgstr "{0} फ़ाइल से आयात किया"

#, java-format
msgid "Loaded {0} entry from file"
msgid_plural "Loaded {0} entries from file"
msgstr[0] "{0} प्रविष्टि फ़ाइल से लोड की गई"
msgstr[1] "{0} प्रविष्टियाँ फ़ाइल से लोड की गईं"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "{0} दुप्लिकेट प्रविष्टि फ़ाइल से कूद गई"
msgstr[1] "{0} दुप्लिकेट प्रविष्टियाँ फ़ाइल से कूद गईं"

msgid "Import from file failed"
msgstr "फ़ाइल से आयात विफल हो गया"

msgid "Subscriptions saved."
msgstr "सब्सक्रिप्शन सहेजे गए।"

msgid "Update"
msgstr "अपडेट"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "सब्सक्रिप्शन स्रोतों से पत्रिका अपडेट करने की कोशिश की जा रही है..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "सब्सक्रिप्शन अपडेट नहीं किया जा सकता: HTTP प्रोक्सी चल नहीं रहा है!"

msgid "Subscriptions reloaded."
msgstr "सब्सक्रिप्शन पुनः लोड किए गए।"

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "यदि DNS को आपकी राउटर पत्रिका प्रकाशित करने के लिए सेट किया गया है, तो प्रविष्टियाँ आपकी प्रकाशित पत्रिका में दिखाई देंगी और साझा करने के लिए hosts.txt फ़ाइल में सहेजी जाएंगी।"

msgid "Published Addressbook"
msgstr "प्रकाशित पत्रिका"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "DNS को आपकी राउटर पत्रिका को आपकी प्रकाशित पत्रिका में डालने के लिए सेट करने के लिए, सेटिंग पृष्ठ पर 'should_publish=true' रखें।"

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "सब्सक्रिप्शन से प्राप्त सभी मेजबानों को इस पत्रिका में दिखाई देगा, इसके अलावा जो कोई भी आप मानवीय रूप से यहाँ या अपनी मास्टर पत्रिका में जोड़ते हैं।"

msgid "Router Addressbook"
msgstr "राउटर पत्रिका"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "आप यहाँ मानवीय रूप से जोड़े हुए मेजबान अभी भी प्रकाशित नहीं होंगे। आप यहाँ अन्य पत्रिकाओं में मेजबानों के अलियास भी जोड़ सकते हैं।"

msgid "Private Addressbook"
msgstr "निजी पत्रिका"

msgid "Local Records"
msgstr "स्थानीय रिकॉर्ड"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "I2P अनुप्रयोग (HTTP प्रोक्सी सहित) आपकी स्थानीय पत्रिकाओं में मेजबानों का उपयोग करके .i2p होस्टनाम को हल करते हैं।"

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "अतिरिक्त सब्सक्रिप्शन राउटर मदद पेज के FAQ खंड में पाए जाएंगे।"

msgid "Subscriptions"
msgstr "सब्सक्रिप्शन"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "सब्सक्रिप्शन से प्राप्त मेजबानों को आपकी राउटर पत्रिका में जोड़ा जाता है और यह अपने आप सिंक किया जाता है (डिफ़ॉल्ट रूप से हर 12 घंटे में)।"

msgid "Configure Subscriptions"
msgstr "सब्सक्रिप्शन कॉन्फ़िगर करें"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "यदि आप यहाँ मानवीय रूप से मेजबान जोड़ते हैं, तो वे आपकी प्रकाशित पत्रिका में शामिल होंगे (अगर सेट किया गया हो)।"

msgid "Master Addressbook"
msgstr "मास्टर पत्रिका"

msgid "Searchable by"
msgstr "खोज सकते हैं"

msgid "I2P applications"
msgstr "I2P अनुप्रयोग"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "मास्टर, राउटर और निजी पत्रिकाएं साझा करके I2P अनुप्रयोगों के लिए DNS प्राधिकरण के रूप में कार्य करती हैं।"

msgid "Optional,"
msgstr "वैकल्पिक,"

msgid "for websites"
msgstr "वेबसाइटों के लिए"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "यदि आप DNS को अपनी राउटर पत्रिका प्रकाशित करने के लिए सेट करते हैं, तो यह एक hosts.txt फ़ाइल निर्यात करेगा जो सभी मेजबानों को सामग्री करेगी (डिफ़ॉल्ट रूप से आपके eepsite के रूट में)।"

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "मास्टर पत्रिका में मानवीय रूप से जोड़े गए पते आपकी राउटर पत्रिका में मिलेंगे।"

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "सब्सक्रिप्शन से आपको मिले मेजबान आपकी राउटर पत्रिका में मिलेंगे।"

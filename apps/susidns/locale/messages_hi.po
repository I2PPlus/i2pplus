msgstr[1] "पुस्तक में {0} प्रविष्टियाँ हैं"

msgid "Add"
msgstr "जोड़ें"

msgid "Replace"
msgstr "बदलें"

#, java-format
msgid "Host name {0} is already in address book, unchanged."
msgstr "होस्ट नाम {0} पहले से ही पत्रिका में है, अपरिवर्तित।"

#, java-format
msgid "Host name {0} is already in address book with a different destination. Click \"Replace\" to overwrite."
msgstr "होस्ट नाम {0} पहले से ही पत्रिका में है, एक अलग गंतव्य के साथ। \"बदलें\" क्लिक करें जांचने के लिए।"

msgid "Unable to resolve Base 32 address"
msgstr "बेस 32 पता हल्ने में असमर्थ"


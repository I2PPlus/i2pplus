#, java-format
msgid "Host name \"{0}\" contains illegal character {1}"
msgstr "གཟིགས་མིང་\"{0}\"ལ་སྤྱོད་མི་ཆོག་པའི་ཡིག་ཆའི་རྟགས་{1}ཡོད་པ་བཞག"

#, java-format
msgid "Host name cannot start with \"{0}\""
msgstr "གཟིགས་མིང་གི་མཐའ་\"{0}\"ནས་འགོ་མ་ཆོག"

#, java-format
msgid "Host name cannot end with \"{0}\""
msgstr "གཟིགས་མིང་གི་མཇུག་\"{0}\"ནས་མཇུག་མ་ཆོག"

#, java-format
msgid "Host name cannot contain \"{0}\""
msgstr "གཟིགས་མིང་ལ་\"{0}\"བཞག་མི་ཆོག"

#, java-format
msgid "Host name \"{0}\" requires conversion to ASCII but the conversion library is unavailable in this JVM"
msgstr "གཟིགས་མིང་\"{0}\" ASCIIརུ་བསྒྱུར་དགོས་པ་ཐུབ་མ་བྱུང་། འོད་སྐྱོན་འདིའི་JVMལ་བསྒྱུར་རིགས་ཀྱི་ཚོད་མེད་པ་བཞག"

msgid "Source"
msgstr "རིགས་འབྲེལ།"

msgid "Imported from"
msgstr "ཡིག་ཆ་ནས་བཞེད་པ།"

msgid "Imported from file"
msgstr "ཡིག་ཆ་ནས་བཞེད་པ་བཞག"

msgid "Manually added via SusiDNS"
msgstr "DNSགྱི་རྒྱུ་མཐུད་སྣོན་པ།"

msgid "Manually added"
msgstr "མཐུད་རིམ་སྣོན་པ།"

msgid "Added via address helper"
msgstr "གཟིགས་མིང་གི་རོགས་པ་ནས་སྣོན་པ།"

msgid "Via helper"
msgstr "རོགས་པ་ནས།"

msgid "Via helper from"
msgstr "རོགས་པ་ནས་བཞེད་པ།"

msgid "None"
msgstr "མེད"

msgid "Hidden"
msgstr "སྒྲིབས་པ།"

msgid "Signed"
msgstr "བརྐྱ་ཡིག་མངོན་པ།"

msgid "Key"
msgstr "གསང་ལྡན"

#, java-format
msgid "Type {0}"
msgstr "རིགས་{0}"

msgid "DSA 1024 bit"
msgstr "DSA 1024 གཞི་གྲངས།"

msgid "ElGamal 2048 bit"
msgstr "ElGamal 2048 གཞི་གྲངས།"

msgid "Search for <span class=active>"
msgid_plural "Search for <span class=active>"
msgstr[0] "<span class=active>ཡི་གཞིར་བཟོས་འཚོལ་བ།"
msgstr[1] "<span class=active>ཡི་གཞིར་བཟོས་འཚོལ་བ།"

#, java-format
msgid "Filtered list contains 1 entry."
msgid_plural "Filtered list contains {0} entries."
msgstr[0] "དྲམ་བཤེར་གྱི་རེའི་ཐོག་ཁ་པ་གཅིག་ཡོད།"
msgstr[1] "དྲམ་བཤེར་གྱི་རེའི་ཐོག་ཁ་པ་{0}ཡོད།"

#, java-format
msgid "One result for: <span class=active>"
msgid_plural "{0} results for: <span class=active>"
msgstr[0] "<span class=active>ཡི་གཞིར་བཟོས་གྲངས་གཅིག་གི་འབྲས་བུ་ཡོད།"
msgstr[1] "<span class=active>ཡི་གཞིར་བཟོས་གྲངས་{0}གི་འབྲས་བུ་ཡོད།"

#, java-format
msgid "Book contains 1 entry"
msgid_plural "Book contains {0} entries"
msgstr[0] "ཡིག་ཆ་བང་ན་ཁ་པ་གཅིག་ཡོད།"
msgstr[1] "ཡིག་ཆ་བང་ན་ཁ་པ་{0}ཡོད།"

msgid "Add"
msgstr "སྣོན་པ།"

msgid "Replace"
msgstr "བརྗེ་བ།"

#, java-format
msgid "Host name {0} is already in address book, unchanged."
msgstr "གཟིགས་མིང་{0}ངེས་པར་དུ་ཐོག་མར་གྱི་ཡིག་ཆ་བང་གི་ཡོད་པས་འགྱུར་མེད།"

#, java-format
msgid "Host name {0} is already in address book with a different destination. Click \"Replace\" to overwrite."
msgstr "གཟིགས་མིང་{0}ངེས་པར་དུ་ཐོག་མར་གྱི་ཡིག་ཆ་བང་གི་ཡོད་པས་འབྲས་བུ་མི་མཚུངས། \"བརྗེ་བ\"ཞིག་དུ་མནན་ནས་བརྗེ་བར་བྱ་དགོས།"

msgid "Unable to resolve Base 32 address"
msgstr "32 གཞི་གྲངས་ཀྱི་གཟིགས་མིང་བཤེར་རྒྱུ་མི་ཐུབ།"

#, java-format
msgid "Destination added for {0}."
msgstr "{0}གི་འབྲས་བུ་སྣོན་པ།"

#, java-format
msgid "Destination changed for {0}."
msgstr "{0}གི་འབྲས་བུ་འགྱུར་བ།"

msgid "Warning - host name does not end with \".i2p\""
msgstr "ཨང་རྟགས་-གཟིགས་མིང་གི་མཇུག་ན་\".i2p\"མེད།"

msgid "Invalid Base 32 host name."
msgstr "32 གཞི་གྲངས་ཀྱི་གཟིགས་མིང་བཟོ་མི་རུང་བ།"

msgid "Invalid Base 64 destination."
msgstr "64 གཞི་གྲངས་ཀྱི་འབྲས་བུ་བཟོ་མི་རུང་བ།"

#, java-format
msgid "Invalid host name \"{0}\"."
msgstr "གཟིགས་མིང་\"{0}\"བཟོ་མི་རུང་བ།"

msgid "Please enter a host name and destination"
msgstr "གཟིགས་མིང་དང་འབྲས་བུ་འཇུག་རོགས།"

msgid "Delete Entry"
msgstr "ཁ་པ་སོར་ཆུབ།"

msgid "Delete Selected"
msgstr "འདེམས་པ་སོར་ཆུབ།"

#, java-format
msgid "Destination {0} deleted."
msgstr "འབྲས་བུ་{0}སོར་ཆུབ་པ།"

#, java-format
msgid "1 destination deleted."
msgid_plural "{0} destinations deleted."
msgstr[0] "འབྲས་བུ་གཅིག་སོར་ཆུབ་པ།"
msgstr[1] "འབྲས་བུ་{0}སོར་ཆུབ་པ།"

msgid "No valid entries selected to delete."
msgstr "སོར་ཆུབ་པར་འདེམས་པའི་ཁ་པ་ཡོད་མེད།"

msgid "Add Alternate"
msgstr "གཞན་དག་སྣོན་པ།"

msgid "Address book saved."
msgstr "ཡིག་ཆ་བང་བརྟན་པོར་བཞག"

msgid "ERROR: Could not write addressbook file."
msgstr "འབྲས་བུ། ཡིག་ཆ་བང་གི་ཡིག་ཆ་བཟོ་མི་ཐུབ།"

msgid "Invalid form submission, probably because you used the \"back\" or \"reload\" button on your browser. Please resubmit."
msgstr "ཕབ་རྒྱུ་བཟོ་མི་རུང་བ། ཤོག་གི་ཕབ་རྒྱུ་བཟོས་པས་མི་ཐུབ་པ་ཐུབ་པ་བཞག། དོ་ཤེས་ཕབ་རྒྱུ་བཟོ་རོགས།"

msgid "If the problem persists, verify that you have cookies enabled in your browser."
msgstr "གནད་དོན་འདི་བརྟན་ན་ཤོག་གི་བོད་གདམས་གྲངས་རུ་Cookieབཞེངས་ཡོད་མེད་བཤེར་རོགས།"

msgid "Save"
msgstr "བརྟན་པོར་བཞག"

msgid "Blacklist saved."
msgstr "མི་ཆོག་པའི་ཐོ་གཞུང་བརྟན་པོར་བཞག"

msgid "Reload"
msgstr "ཡང་དག་བཞེངས་པ།"

msgid "Blacklist reloaded from file."
msgstr "མི་ཆོག་པའི་ཐོ་གཞུང་ཡིག་ཆ་ནས་ཡང་དག་བཞེངས་པ།"

msgid "Configuration saved."
msgstr "སྒྲིག་འཇུག་བརྟན་པོར་བཞག"

msgid "Configuration reloaded."
msgstr "སྒྲིག་འཇུག་ཡང་དག་བཞེངས་པ།"

msgid "New domain"
msgstr "གཞི་གྲངས་གསར་པ།"

msgid "Subscription log reloaded."
msgstr "འབྲེལ་ཡོད་པའི་ཉིན་ཐོག་ཡང་དག་བཞེངས་པ།"

#, java-format
msgid "{0} address book in {1} database"
msgstr "{1}གྱི་ཚོད་ཀྱི་ནང་ཡིག་ཆ་བང་{0}"

#, java-format
msgid "Host name {0} is not in the address book."
msgstr "གཟིགས་མིང་{0}ཡིག་ཆ་བང་གི་ནང་མེད།"

#, java-format
msgid "Failed to add Destination for {0} to naming service {1}"
msgstr "{0}གི་འབྲས་བུ་{1}གྱི་མིང་གི་རིགས་སུ་སྣོན་མི་ཐུབ།"

#, java-format
msgid "Failed to delete Destination for {0} from naming service {1}"
msgstr "{0}གི་འབྲས་བུ་{1}གྱི་མིང་གི་རིགས་ནས་སོར་ཆུབ་མི་ཐུབ།"

msgid "Blacklist Selected"
msgstr "འདེམས་པའི་མི་ཆོག་པའི་ཐོ་གཞུང་།"

#, java-format
msgid "1 destination blacklisted."
msgid_plural "{0} destinations blacklisted."
msgstr[0] "འབྲས་བུ་གཅིག་མི་ཆོག་པའི་ཐོ་གཞུང་ནས་བཞག"
msgstr[1] "འབྲས་བུ་{0}མི་ཆོག་པའི་ཐོ་གཞུང་ནས་བཞག"

msgid "No valid entries selected to blacklist."
msgstr "མི་ཆོག་པའི་ཐོ་གཞུང་ནས་བཞེད་པར་འདེམས་པའི་ཁ་པ་ཡོད་མེད།"

msgid "Save Notes"
msgstr "ཐོ་ཡིག་བརྟན་པོར་བཞག"

msgid "You must enter a file"
msgstr "ཡིག་ཆ་ཞིག་འཇུག་དགོས།"

msgid "No entries found in file"
msgstr "ཡིག་ཆ་ནང་ཁ་པ་མེད་པ།"

#, java-format
msgid "Imported from file {0}"
msgstr "ཡིག་ཆ་{0}ནས་བཞེད་པ་བཞག"

#, java-format
msgid "Loaded {0} entry from file"
msgid_plural "Loaded {0} entries from file"
msgstr[0] "ཡིག་ཆ་ནས་ཁ་པ་{0}བཞེད་པ་བཞག"
msgstr[1] "ཡིག་ཆ་ནས་ཁ་པ་{0}བཞེད་པ་བཞག"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "ཡིག་ཆ་ནས་ཁ་པ་གཞི་གྲངས་{0}བརྐྱང་བ།"
msgstr[1] "ཡིག་ཆ་ནས་ཁ་པ་གཞི་གྲངས་{0}བརྐྱང་བ།"

msgid "Import from file failed"
msgstr "ཡིག་ཆ་ནས་བཞེད་པ་བཞག་མི་ཐུབ།"

msgid "Subscriptions saved."
msgstr "འབྲེལ་ཡོད་པ་བརྟན་པོར་བཞག"

msgid "Update"
msgstr "བསྐྱར་བཏང་བ།"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "འབྲེལ་ཡོད་པའི་རིགས་ནས་ཡིག་ཆ་བང་བསྐྱར་བཏང་བ་བྱེད་བཞིན་པ།"

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "འབྲེལ་ཡོད་པ་བསྐྱར་བཏང་མི་ཐུབ། HTTP གཟིགས་མིང་འཁོར་མེད་པ་བཞག"

msgid "Subscriptions reloaded."
msgstr "འབྲེལ་ཡོད་པ་ཡང་དག་བཞེངས་པ།"

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "DNSགི་སྒྲིག་འཇུག་བྱས་ན་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནི་བཀོད་པའི་ཡིག་ཆ་བང་ནས་བཞེད་པ་བཞག དེ་ནི་hosts.txtཡིག་ཆ་ནས་བཞེད་པ་བཞག"

msgid "Published Addressbook"
msgstr "བཀོད་པའི་ཡིག་ཆ་བང"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "DNSགི་སྒྲིག་འཇུག་བྱས་ན་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནི་བཀོད་པའི་ཡིག་ཆ་བང་ནས་བཞེད་པ་བཞག 'should_publish=true'སྒྲིག་འཇུག་པར་བྱ་དགོས།"

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "འབྲེལ་ཡོད་པའི་རིགས་ནས་བཞེད་པའི་གཟིགས་མིང་ཐམས་ཅད་ཡིག་ཆ་བང་འདིར་བཞག དེ་དང་མཐུད་རིམ་སྣོན་པའི་གཟིགས་མིང་དང་གཙོ་བོའི་ཡིག་ཆ་བང་ནས་སྣོན་པའི་གཟིགས་མིང་བཞག"

msgid "Router Addressbook"
msgstr "གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "ཁྱོད་ཀྱིས་མཐུད་རིམ་སྣོན་པའི་གཟིགས་མིང་བཀོད་མི་ཐུབ། གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནས་གཟིགས་མིང་གི་རིགས་ཀྱི་གཞི་གྲངས་སྣོན་རོགས།"

msgid "Private Addressbook"
msgstr "གསང་བའི་ཡིག་ཆ་བང"

msgid "Local Records"
msgstr "ས་གནས་ཀྱི་ཐོག"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "I2Pགི་རིགས་(HTTP གཟིགས་མིང་གི་རིགས་ཡང་བཞག)ནི་ཁྱོད་ཀྱི་ས་གནས་ཀྱི་ཡིག་ཆ་བང་གི་ནང་དོན་གཟིགས་མིང་བཟོ་བཅོས་བཟོ་བའི་ཐབས་བཞག"

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "འབྲེལ་ཡོད་པའི་རིགས་ཀྱི་གཞི་གྲངས་ལ་བལྟ་བར་གཞི་གྲངས་གཙོ་བོའི་རོགས་པའི་དུས་ཀྱི་FAQབལྟ་རོགས།"

msgid "Subscriptions"
msgstr "འབྲེལ་ཡོད་པ།"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "འབྲེལ་ཡོད་པའི་རིགས་ནས་བཞེད་པའི་གཟིགས་མིང་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནས་སྣོན་པ་བཞག དེ་ནི་རང་རྒྱུ་བཞེད་པ་བཞག (གཞི་གྲངས་ན་ཆུ་ཚོད་12ཡི་རྒྱུ་བཞེད་པ་བཞག)"

msgid "Configure Subscriptions"
msgstr "འབྲེལ་ཡོད་པ་བཟོ་བཅོས་བཟོ་བ།"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "ཁྱོད་ཀྱིས་མཐུད་རིམ་སྣོན་པའི་གཟིགས་མིང་བཀོད་པའི་ཡིག་ཆ་བང་ནས་བཞེད་པ་བཞག (སྒྲིག་འཇུག་བྱས་ན་)"

msgid "Master Addressbook"
msgstr "གཙོ་བོའི་ཡིག་ཆ་བང"

msgid "Searchable by"
msgstr "འཚོལ་བར་བྱ་ཐུབ་པའི་རིགས།"

msgid "I2P applications"
msgstr "I2Pགི་རིགས"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "གཙོ་བོའི་གཞི་གྲངས་གཙོ་བོའི་དང་གསང་བའི་ཡིག་ཆ་བང་གི་རིགས་ཀྱི་ནང་དོན་I2Pགི་རིགས་ཀྱི་DNSགི་རིགས་བཞག"

msgid "Optional,"
msgstr "བཟོ་རིགས་ཀྱི་རྒྱུ་མཐུད།"

msgid "for websites"
msgstr "དྲ་གྲོའི་གཟིགས་མིང་གི་རིགས"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "ཁྱོད་ཀྱི་DNSགི་སྒྲིག་འཇུག་བྱས་ན་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནི་hosts.txtཡིག་ཆ་ནས་བཞེད་པ་བཞག (གཞི་གྲངས་ན་དྲ་གྲོའི་གཟིགས་མིང་གི་མཐའ་ནས་བཞེད་པ་བཞག)"

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "གཙོ་བོའི་ཡིག་ཆ་བང་ནས་མཐུད་རིམ་སྣོན་པའི་གཟིགས་མིང་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནས་བཞེད་པ་བཞག"

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "ཁྱོད་ཀྱི་འབྲེལ་ཡོད་པའི་རིགས་ནས་བཞེད་པའི་གཟིགས་མིང་གཞི་གྲངས་གཙོ་བོའི་ཡིག་ཆ་བང་ནས་བཞེད་པ་བཞག"

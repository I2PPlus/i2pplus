msgid_plural "{0} destinations blacklisted."
msgstr[0] "1 miejsce przeznaczenia zablokowane."
msgstr[1] "{0} miejsca przeznaczenia zablokowane."
msgstr[2] "{0} miejsc przeznaczenia zablokowanych."

msgid "No valid entries selected to blacklist."
msgstr "Nie zaznaczono prawidłowych wpisów do zablokowania."

msgid "Save Notes"
msgstr "Zapisz notatki"

msgid "You must enter a file"
msgstr "Musisz podać plik"

msgid "No entries found in file"
msgstr "Nie znaleziono wpisów w pliku"

#, java-format
msgid "Imported from file {0}"
msgstr "Importowano z pliku {0}"

#, java-format
msgid "Loaded {0} entry from file"
msgid_plural "Loaded {0} entries from file"
msgstr[0] "Załadowany {0} wpis z pliku"
msgstr[1] "Załadowane {0} wpisy z pliku"
msgstr[2] "Załadowane {0} wpisy z pliku"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "Pominęło {0} duplikat wpisu z pliku"
msgstr[1] "Pominęło {0} zduplikowane wpisy z pliku"
msgstr[2] "Pominęło {0} zduplikowane wpisy z pliku"

msgid "Import from file failed"
msgstr "Import z pliku nie powiódł się"

msgid "Subscriptions saved."
msgstr "Subskrypcje zapisane."

msgid "Update"
msgstr "Aktualizacja"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Próba aktualizacji książki adresowej ze źródeł subskrypcji..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Nie można zaktualizować subskrypcji: serwer proxy HTTP nie działa!"

msgid "Subscriptions reloaded."
msgstr "Subskrypcje przeładowane."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Jeżeli DNS został skonfigurowany, aby publikować książkę adresową węzła, to wpisy pojawią się w publicznej książce adresowej i zostaną zapisane w pliku hosts.txt do udostępnienia."

msgid "Published Addressbook"
msgstr "Publiczna książka adresowa"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "Aby skonfigurować DNS tak, aby wpisy książki adresowej węzła pojawiły się w publicznej książce adresowej, ustaw parametr „should_publish=true” na stronie konfiguracji."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Wszystkie adresy pobrane z subskrypcji pojawią się w tej książce adresowej, wraz z ręcznie dodanymi adresami do Twojej głównej książki adresowej."

msgid "Router Addressbook"
msgstr "Książka adresowa węzła"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Adresy dodane tutaj ręcznie nigdy zostaną opublikowane. Możesz także tutaj dodać aliasy do adresów w innych książkach adresowych."

msgid "Private Addressbook"
msgstr "Prywatna książka adresowa"

msgid "Local Records"
msgstr "Lokalne wpisy"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "Aplikacje I2P (wraz z proxy HTTP) używają adresów z Twojej lokalnej książki adresowej do rozwiązywania nazw domen .i2p."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "Dodatkowe subskrypcje można znaleźć w sekcji częste pytania na stronach pomocy węzła."

msgid "Subscriptions"
msgstr "Subskrypcje"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Adresy z Twoich subskrypcji są dodawane do Twojej książki adresowej węzła i automatycznie synchronizowane (domyślnie co 12 godzin)."

msgid "Configure Subscriptions"
msgstr "Konfiguruj subskrypcje"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Jeżeli ręcznie dodasz tutaj adresy, zostaną one uwzględnione w Twojej publicznej książce adresowej (jeżeli skonfigurowana)."

msgid "Master Addressbook"
msgstr "Główna książka adresowa"

msgid "Searchable by"
msgstr "Dostępna dla"

msgid "I2P applications"
msgstr "aplikacji I2P"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "Książki adresowe główna, węzła i prywatna razem działają jako rejestr domen internetowych dla aplikacji I2P."

msgid "Optional,"
msgstr "Opcjonalna,"

msgid "for websites"
msgstr "dla stron"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Jeżeli skonfigurujesz DNS, aby publikować Twoją książkę adresową węzła, to zostanie wyeksportowany plik hosts.txt zawierający wszystkie domeny (domyślnie do katalogu głównego Twojego eepsite'a)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "Adresy ręcznie dodane do Twojej głównej książki adresowej zostaną scalone do książki adresowej węzła."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Adresy pobrane z subskrypcji zostaną scalone do Twojej książki adresowej węzła."

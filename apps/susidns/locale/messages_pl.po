msgstr "Konfiguracja zapisana."

msgid "Configuration reloaded."
msgstr "Konfiguracja przeładowana."

msgid "New domain"
msgstr "Nowy domena"

msgid "Subscription log reloaded."
msgstr "Załadowano ponownie dziennik subskrypcji."


msgstr "Nhập từ tệp không thành công"

msgid "Subscriptions saved."
msgstr "Đã lưu đăng ký."

msgid "Update"
msgstr "Cập nhật"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Đang cố gắng cập nhật sổ địa chỉ từ các nguồn đăng ký..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Không thể cập nhật đăng ký: Proxy HTTP không chạy!"

msgid "Subscriptions reloaded."
msgstr "Đăng ký được tải lại."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Nếu DNS được định cấu hình để xuất bản sổ địa chỉ Bộ định tuyến của bạn, các mục nhập sẽ xuất hiện trong sổ địa chỉ Đã xuất bản của bạn và được lưu vào tệp Hosts.txt để chia sẻ."

msgid "Published Addressbook"
msgstr "Xuất bản sổ địa chỉ"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "Để định cấu hình DNS nhằm đẩy sổ địa chỉ Bộ định tuyến của bạn vào sổ địa chỉ Đã xuất bản, hãy đặt ' Should_publish=true' trên trang cấu hình."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Tất cả các máy chủ có nguồn gốc từ đăng ký sẽ xuất hiện trong sổ địa chỉ này, ngoài bất kỳ máy chủ nào bạn thêm thủ công vào đây hoặc vào sổ địa chỉ Chính của bạn."

msgid "Router Addressbook"
msgstr "Sổ địa chỉ bộ định tuyến"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Máy chủ bạn thêm thủ công ở đây sẽ không bao giờ được công bố. Bạn cũng có thể thêm bí danh vào máy chủ trong các sổ địa chỉ khác ở đây."

msgid "Private Addressbook"
msgstr "Sổ địa chỉ riêng"

msgid "Local Records"
msgstr "Hồ sơ địa phương"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "Các ứng dụng I2P (bao gồm proxy HTTP) sử dụng máy chủ trong sổ địa chỉ cục bộ của bạn để phân giải tên máy chủ .i2p."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "Bạn có thể tìm thấy các đăng ký bổ sung trong phần Câu hỏi thường gặp trên trang trợ giúp Bộ định tuyến."

msgid "Subscriptions"
msgstr "Đăng ký"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Các máy chủ có nguồn gốc từ đăng ký của bạn sẽ được thêm vào sổ địa chỉ Bộ định tuyến của bạn và được tự động đồng bộ hóa (theo mặc định cứ sau 12 giờ)."

msgid "Configure Subscriptions"
msgstr "Cấu hình đăng ký"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Nếu bạn thêm máy chủ ở đây theo cách thủ công, chúng sẽ được đưa vào sổ địa chỉ Đã xuất bản của bạn (nếu được định cấu hình)."

msgid "Master Addressbook"
msgstr "Sổ địa chỉ chính"

msgid "Searchable by"
msgstr "Có thể tìm kiếm theo"

msgid "I2P applications"
msgstr "Ứng dụng I2P"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "Sổ địa chỉ Chính, Bộ định tuyến và Riêng tư đóng vai trò chung là cơ quan quản lý DNS cho các ứng dụng I2P."

msgid "Optional,"
msgstr "Tùy chọn,"

msgid "for websites"
msgstr "dành cho các trang web"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Nếu bạn định cấu hình DNS để xuất bản sổ địa chỉ Bộ định tuyến của mình, nó sẽ xuất tệp Host.txt chứa tất cả các máy chủ (theo mặc định là thư mục gốc của eepsite của bạn)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "Các địa chỉ được thêm thủ công vào sổ địa chỉ Chính của bạn sẽ hợp nhất với sổ địa chỉ Bộ định tuyến của bạn."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Máy chủ bạn nhận được từ đăng ký của mình sẽ hợp nhất với sổ địa chỉ Bộ định tuyến của bạn."

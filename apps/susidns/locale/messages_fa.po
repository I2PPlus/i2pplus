msgid_plural "Loaded {0} entries from file"
msgstr[0] "{0} ورود از پرونده"
msgstr[1] "ورودی های {0} ورودی از پرونده"

#, java-format
msgid "Skipped {0} duplicate entry from file"
msgid_plural "Skipped {0} duplicate entries from file"
msgstr[0] "{0} ورود کپی از پرونده"
msgstr[1] "{0} ورودی های تکراری از پرونده"

msgid "Import from file failed"
msgstr "درون برد از فایل ناموفق بود"

msgid "Subscriptions saved."
msgstr "اشتراک ها ذخیره شدند."

msgid "Update"
msgstr "به روز رسانی"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "تلاش برای به روز رسانی دفترچه آدرس از منابع اشتراک..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "اشتراک ها را نمی توان به روز کرد: پروکسی HTTP اجرا نمی شود!"

msgid "Subscriptions reloaded."
msgstr "اشتراک ها بارگیری مجدد شدند."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "اگر DNS برای انتشار دفترچه آدرس روتر شما پیکربندی شده باشد، ورودی‌ها در دفترچه آدرس منتشر شده شما ظاهر می‌شوند و برای اشتراک‌گذاری در فایل hosts.txt ذخیره می‌شوند."

msgid "Published Addressbook"
msgstr "دفترچه آدرس منتشر شده"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "برای پیکربندی DNS تا دفترچه آدرس روتر شما را به دفترچه آدرس منتشر شده شما منتقل کند، 'should_publish=true' را در صفحه پیکربندی تنظیم کنید."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "همه هاست های مشتق شده از اشتراک ها در این دفترچه آدرس ظاهر می شوند، علاوه بر هر میزبانی که به صورت دستی در اینجا یا به دفترچه آدرس Master خود اضافه می کنید."

msgid "Router Addressbook"
msgstr "دفترچه آدرس روتر"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "هاست هایی که به صورت دستی در اینجا اضافه می کنید هرگز منتشر نمی شوند. "

msgid "Private Addressbook"
msgstr "دفترچه آدرس خصوصی"

msgid "Local Records"
msgstr "سوابق محلی"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "برنامه های I2P (از جمله پروکسی HTTP) از میزبان ها در دفترچه آدرس محلی شما برای حل نام هاست i2p. استفاده می کنند."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "اشتراک‌های اضافی را می‌توانید در بخش پرسش‌های متداول در صفحه راهنمای روتر پیدا کنید."

msgid "Subscriptions"
msgstr "اشتراک ها"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "هاست های منبع شده از اشتراک های شما به دفترچه آدرس روتر شما اضافه می شوند و به طور خودکار همگام سازی می شوند (به طور پیش فرض هر 12 ساعت)."

msgid "Configure Subscriptions"
msgstr "اشتراک ها را پیکربندی کنید"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "اگر به صورت دستی میزبان ها را به اینجا اضافه کنید، آنها شامل دفترچه آدرس منتشر شده شما می شوند (در صورت پیکربندی)."

msgid "Master Addressbook"
msgstr "دفترچه آدرس اصلی"

msgid "Searchable by"
msgstr "قابل جستجو توسط"

msgid "I2P applications"
msgstr "برنامه های I2P"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "دفترچه آدرس Master، Router و Private در مجموع به عنوان مرجع DNS برای برنامه های I2P عمل می کنند."

msgid "Optional,"
msgstr "اختیاری،"

msgid "for websites"
msgstr "برای سایت ها"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "اگر DNS را برای انتشار دفترچه آدرس روتر خود پیکربندی کنید، یک فایل hosts.txt حاوی همه میزبان ها (به طور پیش فرض به ریشه eepsite شما) صادر می کند."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "آدرس هایی که به صورت دستی به دفترچه آدرس Master شما اضافه می شوند با دفترچه آدرس روتر شما ادغام می شوند."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "میزبان هایی که از اشتراک های خود دریافت می کنید با دفترچه آدرس روتر شما ادغام می شوند."

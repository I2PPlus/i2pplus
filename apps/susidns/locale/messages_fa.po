msgstr "افزودن مقصد برای {0} به سرویس نامگذاری {1} انجام نشد"

#, java-format
msgid "Failed to delete Destination for {0} from naming service {1}"
msgstr "حذف مقصد برای {0} از سرویس نامگذاری {1} انجام نشد"

msgid "Blacklist Selected"
msgstr "لیست سیاه انتخاب شده"

#, java-format
msgid "1 destination blacklisted."
msgid_plural "{0} destinations blacklisted."
msgstr[0] "1 مقصد به لیست سیاه اضافه شد."
msgstr[1] "{0} مقصد به لیست سیاه اضافه شدند."

msgid "No valid entries selected to blacklist."
msgstr "هیچ ورودی معتبری برای افزودن به لیست سیاه انتخاب نشده است."

msgid "Save Notes"
msgstr "ذخیره یادداشت ها"

msgid "You must enter a file"
msgstr "شما باید یک فایل وارد کنید"

msgid "No entries found in file"
msgstr "هیچ ورودی در فایل یافت نشد"

#, java-format
msgid "Imported from file {0}"
msgstr "وارد شده از فایل {0}"

#, java-format

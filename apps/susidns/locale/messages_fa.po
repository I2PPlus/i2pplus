msgstr "بارگذاری مجدد"

msgid "Blacklist reloaded from file."
msgstr "لیست سیاه از فایل بارگیری مجدد شد."

msgid "Configuration saved."
msgstr "پیکربندی ذخیره شد."

msgid "Configuration reloaded."
msgstr "پیکربندی مجددا بارگذاری شد."

msgid "New domain"
msgstr "دامنه جدید"

msgid "Subscription log reloaded."
msgstr "گزارش اشتراک بارگیری مجدد شد."


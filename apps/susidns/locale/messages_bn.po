msgstr "আপনার ব্যক্তিগত ঠিকানা বই, এটি কখনও প্রকাশিত হয় না"

msgid "Port for your eepProxy (no need to change)"
msgstr "আপনার eepProxy-এর জন্য পোর্ট (পরিবর্তনের প্রয়োজন নেই)"

msgid "Hostname for your eepProxy (no need to change)"
msgstr "আপনার eepProxy-এর জন্য হোস্টনাম (পরিবর্তনের প্রয়োজন নেই)"

msgid "Whether to update the published addressbook"
msgstr "প্রকাশিত ঠিকানা বই আপডেট করতে হবে কিনা"

msgid "File containing the etags header from the fetched subscription URLs (no need to change)"
msgstr "আনীত সাবস্ক্রিপশন URL থেকে etags হেডার সম্বলিত ফাইল (পরিবর্তনের প্রয়োজন নেই)"

msgid "File containing the modification timestamp for each fetched subscription URL (no need to change)"
msgstr "প্রতি আনীত সাবস্ক্রিপশন URL-এর পরিবর্তন টাইমস্ট্যাম্প সম্বলিত ফাইল (পরিবর্তনের প্রয়োজন নেই)"

msgid "File to log activity to (change to /dev/null if you like)"
msgstr "কার্যকলাপ লগ করার ফাইল (ইচ্ছা হলে /dev/null-এ পরিবর্তন করুন)"

msgid "Name of override theme to use (defaults to console-selected theme)"
msgstr "ব্যবহার করার জন্য ওভাররাইড থিমের নাম (ডিফল্ট কনসোল-নির্বাচিত থিম)"

msgid "Interval (in hours) for running host checker (default is 8 hours)"
msgstr "হোস্ট চেকার চালানোর ব্যবধান ঘন্টায় (ডিফল্ট 8 ঘন্টা)"

msgid "Maximum concurrent pings when running host checker (Default is 12, max is 100)"
msgstr "হোস্ট চেকার চালানোর সময় সর্বোচ্চ সমান্তরাল পিং (ডিফল্ট 12, সর্বোচ্চ 100)"

msgid "delete hosts"
msgstr "হোস্ট মুছুন"


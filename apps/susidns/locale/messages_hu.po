msgstr[1] "{0} ismétlődő bejegyzés kihagyva a fájlból"

msgid "Import from file failed"
msgstr "Nem sikerült importálni a fájlból"

msgid "Subscriptions saved."
msgstr "Feliratkozások elmentve."

msgid "Update"
msgstr "Frissítés"

msgid "Attempting to update addressbook from subscription sources..."
msgstr "Kísérlet a címjegyzék frissítésére előfizetéses forrásokból..."

msgid "Cannot update subscriptions: HTTP proxy is not running!"
msgstr "Nem lehet frissíteni az előfizetéseket: A HTTP-proxy nem fut!"

msgid "Subscriptions reloaded."
msgstr "Feliratkozások újratöltve."

msgid "If SusiDNS is configured to publish your Router address book, the entries will appear in your Published address book and saved to a hosts.txt file for sharing."
msgstr "Ha a DNS úgy van konfigurálva, hogy közzétegye az útválasztó címjegyzékét, a bejegyzések megjelennek a Közzétett címjegyzékben, és egy hosts.txt fájlba kerülnek megosztás céljából."

msgid "Published Addressbook"
msgstr "Kiadott címjegyzék"

msgid "To configure SusiDNS to push your Router address book to your Published address book, set 'should_publish=true' on the configuration page."
msgstr "Ha be szeretné állítani a DNS-t, hogy az útválasztó címjegyzékét a közzétett címjegyzékbe helyezze, állítsa be a 'should_publish=true' értéket a konfigurációs oldalon."

msgid "All hosts derived from subscriptions will appear in this address book, in addition to any you manually add here or to your Master address book."
msgstr "Az előfizetésekből származó összes gazdagép megjelenik ebben a címjegyzékben, azon kívül, amelyet kézzel hozzáadott ide vagy a fő címjegyzékhez."

msgid "Router Addressbook"
msgstr "Router címjegyzéke"

msgid "Hosts you manually add here will never be published. You can also add aliases to hosts in other address books here."
msgstr "Az itt kézzel hozzáadott gazdagépek soha nem lesznek közzétéve. Itt álneveket is hozzáadhat más címjegyzékek gazdagépeihez."

msgid "Private Addressbook"
msgstr "Privát címjegyzék"

msgid "Local Records"
msgstr "Helyi Rekordok"

msgid "I2P applications (including the HTTP proxy) use the hosts in your local address books to resolve .i2p hostnames."
msgstr "Az I2P-alkalmazások (beleértve a HTTP-proxyt is) a helyi címjegyzékekben található gazdagépeket használják az .i2p gazdagépnevek feloldásához."

msgid "Additional subscriptions can be found in the FAQ section of the Router help page."
msgstr "További előfizetések a Router súgóoldalának GYIK részében találhatók."

msgid "Subscriptions"
msgstr "Feliratkozások"

msgid "Hosts sourced from your subscriptions are added to your Router address book, and are automatically synced (by default every 12 hours)."
msgstr "Az előfizetésekből származó gazdagépek hozzáadódnak az útválasztó címjegyzékéhez, és automatikusan szinkronizálódnak (alapértelmezés szerint 12 óránként)."

msgid "Configure Subscriptions"
msgstr "Előfizetések konfigurálása"

msgid "If you manually add hosts here, they will be included your Published address book (if configured)."
msgstr "Ha manuálisan adja hozzá a gazdagépeket, akkor azok megjelennek a közzétett címjegyzékében (ha be van állítva)."

msgid "Master Addressbook"
msgstr "Főcímjegyzék"

msgid "Searchable by"
msgstr "Kereshető"

msgid "I2P applications"
msgstr "I2P alkalmazások"

msgid "The Master, Router and Private address books collectively serve as the DNS authority for I2P applications."
msgstr "A mester, az útválasztó és a privát címjegyzék együttesen az I2P-alkalmazások DNS-hatóságaként szolgál."

msgid "Optional,"
msgstr "Nem kötelező,"

msgid "for websites"
msgstr "webhelyekhez"

msgid "If you configure SusiDNS to publish your Router address book, it will export a hosts.txt file containing all the hosts (by default to the root of your eepsite)."
msgstr "Ha a DNS-t úgy konfigurálja, hogy közzétegye az útválasztó címjegyzékét, akkor exportál egy hosts.txt fájlt, amely tartalmazza az összes gazdagépet (alapértelmezés szerint az eepsite gyökérkönyvtárába)."

msgid "Addresses manually added to your Master address book will merge with your Router address book."
msgstr "A fő címjegyzékbe kézzel hozzáadott címek egyesülnek az útválasztó címjegyzékével."

msgid "Hosts you receive from your subscriptions will merge with your Router address book."
msgstr "Az előfizetésekből kapott gazdagépek egyesülnek az útválasztó címjegyzékével."
